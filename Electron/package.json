{
  "name": "the-exoduser",
  "version": "0.1.0",
  "description": "THE EXODUSER — 지옥의 길 (Hell Road) Action RPG",
  "main": "main.js",
  "author": "심도진",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.exoduser.hellroad",
    "productName": "THE EXODUSER",
    "copyright": "Copyright © 2026 심도진",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "game",
        "filter": [
          "game.html",
          "index.html",
          "server.cjs",
          "favicon.ico",
          "lang_*.js",
          "atlas_*.json",
          "atlas_*.png",
          "proj_atlas.png",
          "img/**/*",
          "video/**/*",
          "bgm/**/*",
          "sfx/**/*",
          "prefabs/**/*",
          "saves/",
          "!docs/**",
          "!node_modules/**",
          "!Electron/**",
          "!_autosave/**",
          "!build/**",
          "!generated/**",
          "!output/**",
          "!tmp_sprites/**",
          "!sprites/**",
          "!boss_assets/**",
          "!boss_3d_poc/**",
          "!vfx_test/**",
          "!tools/**",
          "!test/**",
          "!src/**",
          "!assets/**",
          "!__pycache__/**",
          "!*.cjs",
          "server.cjs",
          "!_tmp_*",
          "!_chest_*",
          "!_debug_*",
          "!ss*.png",
          "!ss_*.png",
          "!screenshot_*.png",
          "!editor*",
          "!tmp_*",
          "!temp_*",
          "!test_*",
          "!*.md",
          "!CLAUDE.md",
          "!.git/**",
          "!.env"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
