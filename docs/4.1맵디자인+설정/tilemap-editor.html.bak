<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>EXODUSER 맵 디자이너</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0a0a0a;color:#ccc;font:12px monospace;display:flex;height:100vh;overflow:hidden;user-select:none}
#nav{width:180px;background:#111;border-right:1px solid #222;display:flex;flex-direction:column;flex-shrink:0}
#nav h2{padding:6px;background:#1a1a1a;color:#ffea00;font-size:13px;text-align:center;border-bottom:1px solid #333}
#chapter-tabs{display:flex;flex-wrap:wrap;padding:2px;gap:2px}
.ch-tab{flex:1;min-width:38px;padding:3px 1px;text-align:center;cursor:pointer;border:1px solid #333;background:#1a1a1a;color:#888;font-size:9px;border-radius:3px}
.ch-tab:hover{background:#222}.ch-tab.active{color:#000;font-weight:bold}
#stage-list{flex:1;overflow-y:auto;padding:3px}
.stage-item{padding:5px 6px;cursor:pointer;border:1px solid transparent;border-radius:3px;margin:1px 0;display:flex;justify-content:space-between;align-items:center}
.stage-item:hover{background:#1a1a1a;border-color:#333}
.stage-item.active{background:#222;border-color:#ffea00}
.stage-item .name{font-size:11px}.stage-item .size{font-size:9px;color:#666}
.stage-item .badge{font-size:8px;padding:1px 4px;border-radius:3px;color:#000}
#nav-footer{padding:5px;border-top:1px solid #333;font-size:10px}
#nav-footer button{width:100%;padding:3px;margin:1px 0;background:#222;color:#ccc;border:1px solid #444;cursor:pointer;font:10px monospace;border-radius:2px}
#nav-footer button:hover{background:#333}
#sidebar{width:210px;background:#131313;border-left:1px solid #222;display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
.section{padding:8px;border-bottom:1px solid #222}
.section h4{color:#888;font-size:11px;margin-bottom:6px}
.tool-row{display:flex;gap:3px;flex-wrap:wrap;margin-bottom:4px}
.tool-btn{padding:6px 4px;background:#222;border:2px solid #444;color:#ccc;cursor:pointer;border-radius:4px;font-size:11px;flex:1;text-align:center;min-width:45px}
.tool-btn:hover{border-color:#888}
.tool-btn.active{border-color:#ffea00;color:#ffea00;background:#2a2a00}
.height-btn{font-size:13px;font-weight:bold;padding:7px 3px}
.slider-row{display:flex;align-items:center;gap:6px;margin:6px 0;font-size:11px}
.slider-row input[type=range]{flex:1}
.slider-row span{min-width:24px;text-align:right;color:#ffea00}
.obj-btn{width:44px;height:44px;display:inline-flex;align-items:center;justify-content:center;margin:2px;border:2px solid #333;cursor:pointer;border-radius:3px;position:relative;vertical-align:top}
.obj-btn:hover{border-color:#ffea00}.obj-btn.active{border-color:#ff4400;box-shadow:0 0 6px #ff440088}
.obj-btn .label{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.85);color:#aaa;font-size:7px;text-align:center;padding:1px}
.undo-btn{background:#553300!important;border-color:#884400!important;color:#ffaa00!important}
#editor{flex:1;position:relative;overflow:hidden}
canvas{display:block}
#hud{position:absolute;top:6px;left:6px;color:#888;font-size:11px;pointer-events:none}
#hud b{color:#ffea00}
#stage-label{position:absolute;bottom:6px;left:6px;color:#ffea00;font-size:13px;font-weight:bold;pointer-events:none}
#show-toggles{position:absolute;top:6px;right:220px;display:flex;gap:3px}
#show-toggles label{font-size:10px;color:#888;cursor:pointer;display:flex;align-items:center;gap:2px;background:#1a1a1a;padding:2px 6px;border-radius:3px;border:1px solid #333}
#show-toggles input{width:12px;height:12px}
#room-info{position:absolute;top:30px;left:6px;color:#666;font-size:10px;pointer-events:none}
</style>
</head><body>
<div id="nav">
  <h2>맵 디자이너</h2>
  <div id="chapter-tabs"></div>
  <div style="display:flex;border-bottom:1px solid #333">
    <div id="mode-normal" style="flex:1;padding:4px 2px;text-align:center;cursor:pointer;background:#222;color:#ffea00;font-size:10px;border-bottom:2px solid #ffea00" onclick="setMapMode('normal')">🗺️맵</div>
    <div id="mode-grid"   style="flex:1;padding:4px 2px;text-align:center;cursor:pointer;background:#1a1a1a;color:#888;font-size:10px;border-bottom:2px solid transparent" onclick="setMapMode('grid')">🔲격자맵</div>
    <div id="mode-boss"   style="flex:1;padding:4px 2px;text-align:center;cursor:pointer;background:#1a1a1a;color:#888;font-size:10px;border-bottom:2px solid transparent" onclick="setMapMode('boss')">💀보스방</div>
  </div>
  <div id="stage-list"></div>
  <div id="nav-footer">
    <button onclick="regenCurrent()" style="background:#002a1a;color:#00ff88;border-color:#00ff88;font-weight:bold">🎲 랜덤재생성</button>
    <button onclick="regenAll()" style="background:#1a1a00;color:#ffea00;border-color:#ffea00">⚡ 전체재생성</button>
    <button onclick="exportAsFixedMap()" style="background:#1a0030;color:#cc88ff;border-color:#cc88ff">📤 내보내기</button>
    <button onclick="exportAll()">JSON전체</button>
    <button onclick="importAll()">불러오기</button>
    <button onclick="saveEditorSettings(true)" style="background:#1a2a00;color:#aaff66;border-color:#aaff66">덮어쓰기 저장</button>
    <button onclick="saveSettingsAsFile()" style="background:#2a001a;color:#ff99cc;border-color:#ff99cc">새 파일로 저장</button>
    <button onclick="loadSettingsFromFile()" style="background:#001f2a;color:#66ddff;border-color:#66ddff">세팅불러오기</button>
    <div style="margin-top:3px;color:#555;font-size:9px" id="stats">-</div>
  </div>
</div>
<div id="editor">
  <canvas id="c"></canvas>
  <div id="hud"><span id="hud-text"></span></div>
  <div id="room-info"></div>
  <div id="show-toggles">
    <label><input type="checkbox" checked onchange="show3d=this.checked;markDirty();saveEditorSettings(false)"> 입체</label>
    <label><input type="checkbox" checked onchange="showObj=this.checked;saveEditorSettings(false)"> 오브젝트</label>
    <label><input type="checkbox" checked onchange="showRooms=this.checked;saveEditorSettings(false)"> 방이름</label>
    <label><input type="checkbox" onchange="showGrid=this.checked;markDirty();saveEditorSettings(false)"> 격자</label>
  </div>
  <div id="stage-label"></div>
</div>
<div id="sidebar">
  <div class="section">
    <h4>⛰️ 지형 높이</h4>
    <div style="color:#555;font-size:9px;margin-bottom:6px">게임 맵 자동 로드됨. 수정만 하세요</div>
    <div class="tool-row">
      <div class="tool-btn height-btn" onclick="setHeight(0)" id="th0" style="color:#ff4400">0 용암</div>
      <div class="tool-btn height-btn active" onclick="setHeight(1)" id="th1" style="color:#4fc3f7">1 바닥</div>
      <div class="tool-btn height-btn" onclick="setHeight(2)" id="th2" style="color:#8bc34a">2 벽</div>
      <div class="tool-btn height-btn" onclick="setHeight(3)" id="th3" style="color:#ffea00">3 높은벽</div>
    </div>
  </div>
  <div class="section">
    <h4>🖌️ 브러시</h4>
    <div class="slider-row">크기 <input type="range" min="1" max="25" value="5" id="brushR" oninput="brushRadius=+this.value;document.getElementById('brVal').textContent=this.value;saveEditorSettings(false)"> <span id="brVal">5</span></div>
    <div class="tool-row">
      <div class="tool-btn active" onclick="setBrush('circle')" id="bs-c">● 원형</div>
      <div class="tool-btn" onclick="setBrush('rect')" id="bs-r">■ 사각</div>
      <div class="tool-btn" onclick="setBrush('box')" id="bs-b">▭ 박스</div>
    </div>
    <div class="tool-row" style="margin-top:6px">
      <div class="tool-btn" onclick="smoothEdges()">✨ 다듬기</div>
      <div class="tool-btn" onclick="reloadMap()">🔄 복원</div>
      <div class="tool-btn undo-btn" onclick="undo()">↩ 되돌리기</div>
    </div>
  </div>
  <div class="section">
    <h4>🎯 오브젝트</h4>
    <div class="tool-row" style="margin-bottom:6px">
      <div class="tool-btn" onclick="selectedObj='_delete';document.querySelectorAll('.obj-btn').forEach(b=>b.classList.remove('active'));for(let i=0;i<=3;i++)document.getElementById('th'+i).classList.remove('active')" style="color:#ff4400;border-color:#ff4400">🗑️ 오브젝트 삭제</div>
    </div>
    <div id="obj-palette"></div>
  </div>
  <div class="section">
    <h4>⌨️ 단축키</h4>
    <div style="color:#555;font-size:9px;line-height:1.8">0~3=높이 []=브러시 C/S/B=모양<br>Ctrl+Z=되돌리기 Ctrl+S=저장 Ctrl+Shift+S=새파일저장</div>
  </div>
</div>
<input type="file" id="fileInput" style="display:none" accept=".json">
<input type="file" id="settingsFileInput" style="display:none" accept=".json">
<script>
const C=document.getElementById('c'),X=C.getContext('2d');
const editor=document.getElementById('editor'),T=8;
let show3d=true,showObj=true,showRooms=true,showGrid=false;
const STAGES=[
  // 1장 썩은숲 (4층, id 0-3)
  {"id":0,"hell":0,"floor":1,"mw":200,"mh":200,"type":"vert"},
  {"id":1,"hell":0,"floor":2,"mw":210,"mh":105,"type":"horiz"},
  {"id":2,"hell":0,"floor":3,"mw":210,"mh":210,"type":"vert"},
  {"id":3,"hell":0,"floor":4,"mw":220,"mh":220,"type":"grid"},
  // 2장 벌레굴 (6층, id 4-9)
  {"id":4,"hell":1,"floor":1,"mw":210,"mh":210,"type":"vert"},
  {"id":5,"hell":1,"floor":2,"mw":220,"mh":110,"type":"horiz"},
  {"id":6,"hell":1,"floor":3,"mw":220,"mh":220,"type":"vert"},
  {"id":7,"hell":1,"floor":4,"mw":230,"mh":115,"type":"horiz"},
  {"id":8,"hell":1,"floor":5,"mw":230,"mh":230,"type":"vert"},
  {"id":9,"hell":1,"floor":6,"mw":240,"mh":240,"type":"grid"},
  // 3장 얼음굴 (4층, id 10-13)
  {"id":10,"hell":2,"floor":1,"mw":230,"mh":230,"type":"vert"},
  {"id":11,"hell":2,"floor":2,"mw":240,"mh":120,"type":"horiz"},
  {"id":12,"hell":2,"floor":3,"mw":240,"mh":240,"type":"vert"},
  {"id":13,"hell":2,"floor":4,"mw":250,"mh":250,"type":"grid"},
  // 4장 화염지대 (7층, id 14-20)
  {"id":14,"hell":3,"floor":1,"mw":240,"mh":240,"type":"vert"},
  {"id":15,"hell":3,"floor":2,"mw":250,"mh":125,"type":"horiz"},
  {"id":16,"hell":3,"floor":3,"mw":250,"mh":250,"type":"vert"},
  {"id":17,"hell":3,"floor":4,"mw":255,"mh":255,"type":"vert"},
  {"id":18,"hell":3,"floor":5,"mw":260,"mh":130,"type":"horiz"},
  {"id":19,"hell":3,"floor":6,"mw":260,"mh":260,"type":"vert"},
  {"id":20,"hell":3,"floor":7,"mw":270,"mh":270,"type":"grid"},
  // 5장 지옥군단 (5층, id 21-25)
  {"id":21,"hell":4,"floor":1,"mw":260,"mh":260,"type":"vert"},
  {"id":22,"hell":4,"floor":2,"mw":270,"mh":135,"type":"horiz"},
  {"id":23,"hell":4,"floor":3,"mw":270,"mh":270,"type":"vert"},
  {"id":24,"hell":4,"floor":4,"mw":280,"mh":280,"type":"vert"},
  {"id":25,"hell":4,"floor":5,"mw":280,"mh":280,"type":"grid"},
  // 6장 사도마굴 (6층, id 26-31)
  {"id":26,"hell":5,"floor":1,"mw":270,"mh":270,"type":"vert"},
  {"id":27,"hell":5,"floor":2,"mw":280,"mh":140,"type":"horiz"},
  {"id":28,"hell":5,"floor":3,"mw":280,"mh":280,"type":"vert"},
  {"id":29,"hell":5,"floor":4,"mw":285,"mh":285,"type":"vert"},
  {"id":30,"hell":5,"floor":5,"mw":290,"mh":145,"type":"horiz"},
  {"id":31,"hell":5,"floor":6,"mw":290,"mh":290,"type":"grid"},
  // 7장 지옥성 (3층, id 32-34)
  {"id":32,"hell":6,"floor":1,"mw":290,"mh":290,"type":"vert"},
  {"id":33,"hell":6,"floor":2,"mw":300,"mh":150,"type":"horiz"},
  {"id":34,"hell":6,"floor":3,"mw":300,"mh":300,"type":"grid"}
];
const HELLS=[
  {name:'1장 썩은숲',color:'#66ee55'},{name:'2장 벌레굴',color:'#aacc44'},
  {name:'3장 얼음굴',color:'#4fc3f7'},{name:'4장 화염지대',color:'#ff6600'},
  {name:'5장 지옥군단',color:'#e040fb'},{name:'6장 사도마굴',color:'#aaaaaa'},
  {name:'7장 지옥성',color:'#ff2020'},
];
const CHAPTER_STAGES=[
  {hell:0,stages:4,startSi:0},{hell:1,stages:6,startSi:4},
  {hell:2,stages:4,startSi:10},{hell:3,stages:7,startSi:14},
  {hell:4,stages:5,startSi:21},{hell:5,stages:6,startSi:26},
  {hell:6,stages:3,startSi:32}
];
const H_COL=['#1a0800','#141a12','#28301e','#3a3a24'];
const H_NAME=['용암','바닥','벽','높은벽'];
const OBJ_DEFS=[
  {id:'player_start',name:'시작점',icon:'🏠',color:'#4fc3f7',cat:'핵심'},
  {id:'boss_pos',name:'보스',icon:'💀',color:'#ff2020',cat:'핵심'},
  {id:'exit',name:'출구',icon:'🚪',color:'#8bc34a',cat:'핵심'},
  {id:'bonfire',name:'안식처',icon:'🔥',color:'#ff8800',cat:'오브젝트'},
  {id:'lore',name:'비석',icon:'📜',color:'#aaaaaa',cat:'오브젝트'},
  {id:'trap',name:'함정',icon:'⚡',color:'#ffcc00',cat:'오브젝트'},
  {id:'altar',name:'제단',icon:'⛩️',color:'#e040fb',cat:'오브젝트'},
  {id:'forge',name:'대장간',icon:'🔨',color:'#ff6600',cat:'오브젝트'},
  {id:'spawn_g0',name:'스폰-일반',icon:'👾',color:'#88ff88',cat:'스폰'},
  {id:'spawn_g1',name:'스폰-강화',icon:'👹',color:'#ffaa00',cat:'스폰'},
  {id:'spawn_g2',name:'스폰-엘리트',icon:'🔱',color:'#ff4400',cat:'스폰'},
  {id:'breakable',name:'파괴물',icon:'🪣',color:'#aa8855',cat:'오브젝트'},
  {id:'hole_s',name:'소환굴-소',icon:'🕳️',color:'#884444',cat:'소환굴'},
  {id:'hole_m',name:'소환굴-중',icon:'🕳️',color:'#aa4444',cat:'소환굴'},
  {id:'hole_l',name:'소환굴-대',icon:'🕳️',color:'#cc4444',cat:'소환굴'},
  {id:'boss_gate',name:'보스문',icon:'🚧',color:'#aa00ff',cat:'보스방'},
  {id:'boss_exit',name:'보스출구',icon:'🚪',color:'#00ff66',cat:'보스방'},
  {id:'pillar',name:'기둥',icon:'🏛️',color:'#888888',cat:'보스방'},
  // ── CH1 썩은숲 ──
  {id:'dead_tree',     name:'고목',       icon:'🌲', color:'#5d4037', cat:'CH1-썩은숲',img:'../../assets/objects/tree_dead_01.png',sz:64,col:1},
  {id:'dead_tree_02',  name:'고목2',      icon:'🌲', color:'#5d4037', cat:'CH1-썩은숲',img:'../../assets/objects/tree_dead_02.png',sz:64,col:1},
  {id:'dead_tree_03',  name:'고목3',      icon:'🌲', color:'#5d4037', cat:'CH1-썩은숲',img:'../../assets/objects/tree_dead_03.png',sz:64,col:1},
  {id:'skull_pile',    name:'해골더미',   icon:'💀', color:'#9e9e9e', cat:'CH1-썩은숲',img:'../../assets/objects/deco_bones_04.png',sz:32},
  {id:'bone_rocks',    name:'뼈바위',     icon:'🪨', color:'#666677', cat:'CH1-썩은숲',img:'../../assets/objects/deco_bones_03.png',sz:32},
  {id:'mushroom_glow', name:'발광버섯',   icon:'🍄', color:'#ff7043', cat:'CH1-썩은숲',img:'../../assets/objects/mushroom_glow_01.png',sz:32,light:1},
  {id:'mushroom_glow_02',name:'발광버섯2',icon:'🍄', color:'#ff7043', cat:'CH1-썩은숲',img:'../../assets/objects/mushroom_glow_02.png',sz:32,light:1},
  {id:'mushroom_glow_03',name:'발광버섯3',icon:'🍄', color:'#ff7043', cat:'CH1-썩은숲',img:'../../assets/objects/mushroom_glow_03.png',sz:32,light:1},
  {id:'poison_pool',   name:'독웅덩이',   icon:'☣️', color:'#76ff03', cat:'CH1-썩은숲',img:'../../assets/objects/ch1_poison_pool_sheet.png',sz:32,sheet:{c:3,r:3}},
  // ── CH2 벌레굴 ──
  {id:'bug_egg',       name:'벌레알',     icon:'🥚', color:'#c0ca33', cat:'CH2-벌레굴',img:'../../assets/objects/ch2_bug_egg_sheet.png',sz:32,sheet:{c:3,r:2}},
  {id:'slime_pool',    name:'점액웅덩이', icon:'🟢', color:'#8bc34a', cat:'CH2-벌레굴',img:'../../assets/objects/ch2_slime_pool_sheet.png',sz:32,sheet:{c:3,r:3}},
  {id:'cocoon',        name:'고치',       icon:'🫘', color:'#6d4c41', cat:'CH2-벌레굴',img:'../../assets/objects/ch2_cocoon_sheet.png',sz:48,col:1,sheet:{c:3,r:3}},
  {id:'bug_nest',      name:'벌레둥지',   icon:'🪺', color:'#4e342e', cat:'CH2-벌레굴',img:'../../assets/objects/ch2_bug_nest_sheet.png',sz:48,col:1,sheet:{c:3,r:3}},
  // ── CH3 얼음굴 ──
  {id:'ice_pillar',    name:'얼음기둥',   icon:'🧊', color:'#4fc3f7', cat:'CH3-얼음굴',img:'../../assets/objects/ch3_ice_pillar_sheet.png',sz:64,col:1,sheet:{c:3,r:3}},
  {id:'ice_deco',      name:'얼음데코',   icon:'❄️', color:'#b3e5fc', cat:'CH3-얼음굴',img:'../../assets/objects/ch3_ice_deco_sheet.png',sz:32,sheet:{c:3,r:3}},
  {id:'ice_floor',     name:'얼음바닥',   icon:'🧊', color:'#1a3a5c', cat:'CH3-얼음굴',img:'../../assets/tiles/ch3_floor_sheet.png',sz:40,sheet:{c:3,r:3}},
  {id:'frozen_bones',  name:'냉동뼈',     icon:'🦴', color:'#90caf9', cat:'CH3-얼음굴',img:'../../assets/objects/ch3_frozen_bones_sheet.png',sz:32,sheet:{c:3,r:3}},
  // ── CH4 화염 ──
  {id:'lava_crack',    name:'용암균열',   icon:'🌋', color:'#ff3d00', cat:'CH4-화염',img:'../../assets/objects/ch4_lava_crack_sheet.png',sz:40,sheet:{c:3,r:3}},
  {id:'fire_pillar',   name:'불기둥',     icon:'🔥', color:'#ff6d00', cat:'CH4-화염',img:'../../assets/objects/ch4_fire_pillar_sheet.png',sz:64,col:1,sheet:{c:3,r:3}},
  // ── CH5 뇌전 ──
  {id:'tesla_coil',    name:'번개기둥',   icon:'⚡', color:'#42a5f5', cat:'CH5-뇌전',img:'../../assets/objects/ch5_tesla_sheet.png',sz:64,col:1,sheet:{c:4,r:2}},
  {id:'spark_crystal', name:'방전수정',   icon:'💎', color:'#29b6f6', cat:'CH5-뇌전',img:'../../assets/objects/ch5_spark_crystal_sheet.png',sz:32,sheet:{c:3,r:3}},
  {id:'thunder_mark',  name:'뇌전각인',   icon:'⚡', color:'#1565c0', cat:'CH5-뇌전',img:'../../assets/objects/ch5_thunder_mark_sheet.png',sz:40,sheet:{c:3,r:3}},
  // ── CH6 백골 ──
  {id:'bone_pillar',   name:'뼈기둥',     icon:'🦴', color:'#d7ccc8', cat:'CH6-백골',img:'../../assets/objects/ch6_bone_pillar_sheet.png',sz:64,col:1,sheet:{c:3,r:3}},
  {id:'gravestone',    name:'묘비',       icon:'🪦', color:'#78909c', cat:'CH6-백골',img:'../../assets/objects/ch6_gravestone_sheet.png',sz:48,col:1,sheet:{c:3,r:3}},
  // ── CH7 지옥성 ──
  {id:'rune_mark',     name:'차원균열',   icon:'🔮', color:'#aa00ff', cat:'CH7-지옥성',img:'../../assets/objects/ch7_rune_mark_sheet.png',sz:40,sheet:{c:3,r:3}},
];
// ── 오브젝트 이미지 프리로드 ──
const _objImgs={};
OBJ_DEFS.forEach(d=>{if(d.img){const im=new Image();im.src=d.img;_objImgs[d.id]=im}});
// ══ 카빙 함수 ══
function _tCarveCircle(map,mw,mh,cx,cy,r){
  const r2=r*r;
  for(let dy=-r;dy<=r;dy++)for(let dx=-r;dx<=r;dx++){
    if(dx*dx+dy*dy>r2)continue;
    const tx=cx+dx,ty=cy+dy;
    if(tx>0&&tx<mw-1&&ty>0&&ty<mh-1)map[ty][tx]=0;
  }
}
function _tCarveEllipse(map,mw,mh,cx,cy,rx,ry){
  for(let dy=-ry;dy<=ry;dy++)for(let dx=-rx;dx<=rx;dx++){
    if((dx*dx)/(rx*rx)+(dy*dy)/(ry*ry)>1)continue;
    const tx=cx+dx,ty=cy+dy;
    if(tx>0&&tx<mw-1&&ty>0&&ty<mh-1)map[ty][tx]=0;
  }
}
function _tCarveRect(map,mw,mh,cx,cy,rx,ry){
  for(let dy=-ry;dy<=ry;dy++)for(let dx=-rx;dx<=rx;dx++){
    const tx=cx+dx,ty=cy+dy;
    if(tx>0&&tx<mw-1&&ty>0&&ty<mh-1)map[ty][tx]=0;
  }
}
function _tCarveCross(map,mw,mh,cx,cy,rx,ry,armW,armH){
  // 가로 팔
  armW=armW||~~(rx*.7);armH=armH||~~(ry*.7);
  for(let dy=-armH;dy<=armH;dy++)for(let dx=-rx;dx<=rx;dx++){
    const tx=cx+dx,ty=cy+dy;
    if(tx>0&&tx<mw-1&&ty>0&&ty<mh-1)map[ty][tx]=0;
  }
  // 세로 팔
  for(let dy=-ry;dy<=ry;dy++)for(let dx=-armW;dx<=armW;dx++){
    const tx=cx+dx,ty=cy+dy;
    if(tx>0&&tx<mw-1&&ty>0&&ty<mh-1)map[ty][tx]=0;
  }
}
function _tCarveCorridor(map,mw,mh,x1,y1,x2,y2,width,style){
  const hw=~~(width/2);
  if(style==='straight'){
    // L자 직선: 먼저 수평, 다음 수직
    const minX=Math.min(x1,x2)-hw,maxX=Math.max(x1,x2)+hw;
    const minY=Math.min(y1,y2)-hw,maxY=Math.max(y1,y2)+hw;
    // 수평 구간
    for(let x=Math.max(1,minX);x<=Math.min(mw-2,maxX);x++)
      for(let dy=-hw;dy<=hw;dy++){const ty=y1+dy;if(ty>0&&ty<mh-1)map[ty][x]=0}
    // 수직 구간
    for(let y=Math.max(1,Math.min(y1,y2));y<=Math.min(mh-2,Math.max(y1,y2));y++)
      for(let dx=-hw;dx<=hw;dx++){const tx=x2+dx;if(tx>0&&tx<mw-1)map[y][tx]=0}
  }else if(style==='zigzag'){
    const midY=~~((y1+y2)/2);
    // y1→midY at x1
    for(let y=Math.min(y1,midY);y<=Math.max(y1,midY);y++)
      for(let dx=-hw;dx<=hw;dx++){const tx=x1+dx;if(tx>0&&tx<mw-1&&y>0&&y<mh-1)map[y][tx]=0}
    // x1→x2 at midY
    for(let x=Math.min(x1,x2);x<=Math.max(x1,x2);x++)
      for(let dy=-hw;dy<=hw;dy++){const ty=midY+dy;if(ty>0&&ty<mh-1&&x>0&&x<mw-1)map[ty][x]=0}
    // midY→y2 at x2
    for(let y=Math.min(midY,y2);y<=Math.max(midY,y2);y++)
      for(let dx=-hw;dx<=hw;dx++){const tx=x2+dx;if(tx>0&&tx<mw-1&&y>0&&y<mh-1)map[y][tx]=0}
  }else{ // cave — 노이즈로 자연스럽게
    const dx=x2-x1,dy=y2-y1;
    const dist=Math.sqrt(dx*dx+dy*dy);
    const steps=Math.max(1,~~(dist));
    for(let i=0;i<=steps;i++){
      const t=i/steps;
      const px=~~(x1+dx*t),py=~~(y1+dy*t);
      const noise=Math.sin(i*0.3)*1.5+Math.sin(i*0.13+5)*0.8;
      const w=Math.max(3,hw+~~(noise));
      for(let d=-w;d<=w;d++){
        const tx=px+~~(d*(Math.abs(dy)>Math.abs(dx)?1:0));
        const ty=py+~~(d*(Math.abs(dx)>=Math.abs(dy)?1:0));
        // 주축에 수직으로 넓히기
        if(Math.abs(dx)>=Math.abs(dy)){
          // 주로 수평 → 세로로 넓힘
          if(py+d>0&&py+d<mh-1&&px>0&&px<mw-1)map[py+d][px]=0;
        }else{
          // 주로 수직 → 가로로 넓힘
          if(py>0&&py<mh-1&&px+d>0&&px+d<mw-1)map[py][px+d]=0;
        }
      }
    }
  }
}
function _tCaveSmooth(map,mw,mh,passes){
  for(let pass=0;pass<passes;pass++){
    const tmp=[];for(let y=0;y<mh;y++){tmp[y]=[];for(let x=0;x<mw;x++)tmp[y][x]=map[y][x]}
    for(let y=2;y<mh-2;y++)for(let x=2;x<mw-2;x++){
      if(tmp[y][x]!==1)continue;
      let floorN=0;
      for(let dy=-1;dy<=1;dy++)for(let dx=-1;dx<=1;dx++){if(dx===0&&dy===0)continue;if(tmp[y+dy][x+dx]===0)floorN++}
      if(floorN>=5)map[y][x]=0;
      else if(floorN>=3&&Math.random()<(pass===0?.4:.25))map[y][x]=0;
    }
  }
}

function _tNearestWalkable(map,mw,mh,cx,cy){
  const sx=Math.max(1,Math.min(mw-2,~~cx)), sy=Math.max(1,Math.min(mh-2,~~cy));
  if(map[sy]&&map[sy][sx]===0)return{x:sx,y:sy};
  const q=[{x:sx,y:sy}],vis=[];
  for(let y=0;y<mh;y++){vis[y]=new Uint8Array(mw)}
  vis[sy][sx]=1;
  const dirs=[[1,0],[-1,0],[0,1],[0,-1]];
  while(q.length){
    const c=q.shift();
    for(const d of dirs){
      const nx=c.x+d[0],ny=c.y+d[1];
      if(nx<1||ny<1||nx>=mw-1||ny>=mh-1||vis[ny][nx])continue;
      vis[ny][nx]=1;
      if(map[ny][nx]===0)return{x:nx,y:ny};
      q.push({x:nx,y:ny});
    }
  }
  return null;
}
function _tHasPath(map,mw,mh,sx,sy,tx,ty){
  if(sx<0||sy<0||tx<0||ty<0||sx>=mw||tx>=mw||sy>=mh||ty>=mh)return false;
  if(map[sy][sx]!==0||map[ty][tx]!==0)return false;
  const q=[{x:sx,y:sy}],vis=[];
  for(let y=0;y<mh;y++){vis[y]=new Uint8Array(mw)}
  vis[sy][sx]=1;
  const dirs=[[1,0],[-1,0],[0,1],[0,-1]];
  while(q.length){
    const c=q.shift();
    if(c.x===tx&&c.y===ty)return true;
    for(const d of dirs){
      const nx=c.x+d[0],ny=c.y+d[1];
      if(nx<1||ny<1||nx>=mw-1||ny>=mh-1||vis[ny][nx])continue;
      if(map[ny][nx]!==0)continue;
      vis[ny][nx]=1;
      q.push({x:nx,y:ny});
    }
  }
  return false;
}
function _tEnsurePath(map,mw,mh,fromPt,toPt,width){
  const a=_tNearestWalkable(map,mw,mh,fromPt.x,fromPt.y);
  const b=_tNearestWalkable(map,mw,mh,toPt.x,toPt.y);
  if(!a||!b)return;
  if(_tHasPath(map,mw,mh,a.x,a.y,b.x,b.y))return;
  const w=Math.max(5,width||7);
  _tCarveCorridor(map,mw,mh,a.x,a.y,b.x,b.y,w,'straight');
  _tCarveCorridor(map,mw,mh,a.x,a.y,b.x,b.y,Math.max(4,w-1),'cave');
}
function _pickCorridorStyle(rng,floor,hell){
  const r=rng();
  if(floor<=2)return r<0.7?'cave':(r<0.88?'straight':'zigzag');
  if(floor>=8||hell>=3)return r<0.35?'cave':(r<0.72?'zigzag':'straight');
  return r<0.55?'cave':(r<0.8?'zigzag':'straight');
}

function _tValidateConnectivity(map,mw,mh,startCx,startCy){
  const vis=[];for(let y=0;y<mh;y++){vis[y]=[];for(let x=0;x<mw;x++)vis[y][x]=false}

// ══ FIXED_MAPS ══

  // ── 소환굴 배치 ──
  const spawnHoles=[];
  const bossRoomRef=rooms.find(r=>r.type==='boss');
  const bossDistMax=bossRoomRef?bossRoomRef.cy:1;
  for(let ri=0;ri<rooms.length;ri++){
    const r=rooms[ri];
    if(r.type==='start'||r.type==='forge'||r.type==='boss')continue;
    // 보스까지 Y거리로 등급 결정 (가까울수록 높은 등급)
    const distRatio=bossDistMax>0?Math.max(0,1-(r.cy/bossDistMax)):0;
    const grade=Math.min(3,~~(distRatio*4));
    const hx=(r.cx+.5)*T,hy=(r.cy+.5)*T;
    spawnHoles.push({x:hx,y:hy,grade,timer:SPAWN_HOLE[grade].interval*(.5+Math.random()*.5),alive:0,room:ri});
  }
  // 복도 spine 중간에 grade 0 균열 2~4개
  const corridorCnt=2+~~(Math.random()*3);
  const spineStep=Math.max(1,~~(spine.length/corridorCnt));
  for(let ci=0;ci<corridorCnt;ci++){
    const si2=Math.min(spine.length-1,~~(spineStep*(ci+.5)));
    const sp2=spine[si2];if(!sp2)continue;
    const hx2=(sp2.cx+.5)*T,hy2=(sp2.y+.5)*T;
    // 방 내부가 아닌지 확인
    let inRoom=false;
    for(const r of rooms){if(sp2.cx>=r.x&&sp2.cx<=r.x+r.w&&sp2.y>=r.y&&sp2.y<=r.y+r.h){inRoom=true;break}}
    if(!inRoom)spawnHoles.push({x:hx2,y:hy2,grade:0,timer:SPAWN_HOLE[0].interval*(.5+Math.random()*.5),alive:0,room:-1});
  }

  G.rooms=rooms;G.map=map;G.mw=mw;G.mh=mh;G.exits=exits;G.bossAlive=true;
  G.bossGate=_gateTiles;G.bossGateOpen=false;G.bossSealed=false;G._bossCx=bossCx;G._bossCy=bossCy;G._gateY=_gateY;G._bossEntY=(_gateY-2+.5);
  G.spawnHoles=spawnHoles;
}

