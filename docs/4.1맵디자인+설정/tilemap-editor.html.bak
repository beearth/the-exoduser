// ═══ MAP — 고정맵 생성기 ═══

// ══ 맵 생성 ══
function generateMap(si){
  const tmpl=FIXED_MAPS[si];if(!tmpl)return null;
  const mw=tmpl.mw,mh=tmpl.mh,map=[];
  for(let y=0;y<mh;y++){map[y]=[];for(let x=0;x<mw;x++)map[y][x]=1}
  const rooms=[];
  for(const rd of tmpl.rooms){
    const cx=rd.cx,cy=rd.cy,rx=rd.rx||8,ry=rd.ry||rx;
    if(rd.shape==='ellipse')_tCarveEllipse(map,mw,mh,cx,cy,rx,ry);
    else if(rd.shape==='circle')_tCarveCircle(map,mw,mh,cx,cy,rx);
    else if(rd.shape==='rect')_tCarveRect(map,mw,mh,cx,cy,rx,ry);
    else if(rd.shape==='cross'){_tCarveCross(map,mw,mh,cx,cy,rx,ry,rd.armW||~~(rx*.5),rd.armH||~~(ry*.5))}
    if(rd.pillars)for(const p of rd.pillars){for(let dy=0;dy<(p.h||2);dy++)for(let dx=0;dx<(p.w||2);dx++){const tx=cx+p.dx+dx,ty=cy+p.dy+dy;if(tx>0&&tx<mw-1&&ty>0&&ty<mh-1)map[ty][tx]=1}}
    rooms.push({cx,cy,rx,ry,type:rd.type||'combat',id:rd.id});
  }
  for(const cd of tmpl.corridors){
    const f=tmpl.rooms.find(r=>r.id===cd.from),t=tmpl.rooms.find(r=>r.id===cd.to);if(!f||!t)continue;
    const pts=[{x:f.cx,y:f.cy}];if(cd.waypoints)for(const wp of cd.waypoints)pts.push(wp);pts.push({x:t.cx,y:t.cy});
    for(let i=0;i<pts.length-1;i++)_tCarveCorridor(map,mw,mh,pts[i].x,pts[i].y,pts[i+1].x,pts[i+1].y,cd.width||4,cd.style||'cave');
  }
  if(tmpl.features)for(const ft of tmpl.features){if(ft.type==='alcove')_tCarveCircle(map,mw,mh,ft.x,ft.y,ft.r||3)}
  _tCaveSmooth(map,mw,mh,1);
  // generation noise can leave pinched corridors; force corridor segment connectivity
  for(const cd of tmpl.corridors){
    const f=tmpl.rooms.find(r=>r.id===cd.from),t=tmpl.rooms.find(r=>r.id===cd.to);if(!f||!t)continue;
    const pts=[{x:f.cx,y:f.cy}];if(cd.waypoints)for(const wp of cd.waypoints)pts.push(wp);pts.push({x:t.cx,y:t.cy});
    for(let i=0;i<pts.length-1;i++)_tEnsurePath(map,mw,mh,pts[i],pts[i+1],(cd.width||6)+2);
  }
  // ── 보스방 처리 ──
  const bossRd=tmpl.rooms.find(r=>r.type==='boss');
  let gateTiles=[],exitTiles=[];
  if(bossRd){
    const bCx=bossRd.cx,bCy=bossRd.cy,bRx=bossRd.rx||12,bRy=bossRd.ry||bRx;
    // 보스방 바닥 → tile=4
    for(let y=bCy-bRy;y<=bCy+bRy;y++)for(let x=bCx-bRx;x<=bCx+bRx;x++)
      if(y>0&&y<mh-1&&x>0&&x<mw-1&&map[y][x]===0)map[y][x]=4;
    // 가장 가까운 벽으로 게이트 자동 결정
    const dTop=bCy-bRy, dBot=mh-1-(bCy+bRy), dLeft=bCx-bRx, dRight=mw-1-(bCx+bRx);
    const minD=Math.min(dTop,dBot,dLeft,dRight);
    if(minD===dTop){
      for(let gy=0;gy<dTop+1;gy++) for(let gx=bCx-1;gx<=bCx+1;gx++) if(gx>=0&&gx<mw&&gy<mh) map[gy][gx]=0;
      for(let gx=bCx-1;gx<=bCx+1;gx++) if(gx>=0&&gx<mw){map[0][gx]=3;gateTiles.push({x:gx,y:0});}
      for(let gx=bCx-1;gx<=bCx+1;gx++) if(gx>=0&&gx<mw&&mh>1){map[1][gx]=2;exitTiles.push({x:gx,y:1});}
    } else if(minD===dBot){
      for(let gy=bCy+bRy;gy<mh;gy++) for(let gx=bCx-1;gx<=bCx+1;gx++) if(gx>=0&&gx<mw&&gy>=0) map[gy][gx]=0;
      for(let gx=bCx-1;gx<=bCx+1;gx++) if(gx>=0&&gx<mw){map[mh-1][gx]=3;gateTiles.push({x:gx,y:mh-1});}
      for(let gx=bCx-1;gx<=bCx+1;gx++) if(gx>=0&&gx<mw&&mh>1){map[mh-2][gx]=2;exitTiles.push({x:gx,y:mh-2});}
    } else if(minD===dLeft){
      for(let gx=0;gx<dLeft+1;gx++) for(let gy=bCy-1;gy<=bCy+1;gy++) if(gy>=0&&gy<mh&&gx<mw) map[gy][gx]=0;
      for(let gy=bCy-1;gy<=bCy+1;gy++) if(gy>=0&&gy<mh){map[gy][0]=3;gateTiles.push({x:0,y:gy});}
      for(let gy=bCy-1;gy<=bCy+1;gy++) if(gy>=0&&gy<mh&&mw>1){map[gy][1]=2;exitTiles.push({x:1,y:gy});}
    } else {
      for(let gx=bCx+bRx;gx<mw;gx++) for(let gy=bCy-1;gy<=bCy+1;gy++) if(gy>=0&&gy<mh&&gx>=0) map[gy][gx]=0;
      for(let gy=bCy-1;gy<=bCy+1;gy++) if(gy>=0&&gy<mh){map[gy][mw-1]=3;gateTiles.push({x:mw-1,y:gy});}
      for(let gy=bCy-1;gy<=bCy+1;gy++) if(gy>=0&&gy<mh&&mw>1){map[gy][mw-2]=2;exitTiles.push({x:mw-2,y:gy});}
    }
  }
  return{map,mw,mh,rooms,tmpl,gateTiles,exitTiles};
}
function genBossArena(si){
  const at=si%5;
  const mw=50,mh=42;
  const map=[];
  for(let y=0;y<mh;y++){map[y]=[];for(let x=0;x<mw;x++)map[y][x]=1}
  const cx=~~(mw/2),cy=~~(mh/2);
  const il=2,it=2,ir=mw-2,ib=mh-2; // 여백 최소화 — 벽으로 꽉 채움
  if(at===0){// ── 원형 투기장 ──
    const rr=Math.min(ir-il,ib-it)/2-1;
    for(let y=it;y<ib;y++)for(let x=il;x<ir;x++){if((x-cx)*(x-cx)+(y-cy)*(y-cy)<=rr*rr)map[y][x]=4}
    const pr=~~(rr*.5);
    [[0,-pr],[0,pr],[-pr,0],[pr,0]].forEach(([dx,dy])=>{
      for(let py2=cy+dy;py2<=cy+dy+1;py2++)for(let px2=cx+dx;px2<=cx+dx+1;px2++)
        if(py2>=0&&py2<mh&&px2>=0&&px2<mw)map[py2][px2]=1;
    });
  }else if(at===1){// ── 대성당 ──
    for(let y=it;y<ib;y++)for(let x=il;x<ir;x++)map[y][x]=4;
    for(let y=it+4;y<ib-4;y+=4){
      for(let d=0;d<2;d++)for(let d2=0;d2<2;d2++){
        if(y+d<mh){if(il+4+d2<mw)map[y+d][il+4+d2]=1;if(ir-5+d2>=0)map[y+d][ir-5+d2]=1}
      }
    }
  }else if(at===2){// ── 십자형 ──
    const armW=~~((ir-il)*.3),armH=~~((ib-it)*.3);
    for(let y=it;y<ib;y++)for(let x=il;x<ir;x++){if(Math.abs(x-cx)<armW||Math.abs(y-cy)<armH)map[y][x]=4}
  }else if(at===3){// ── 팔각형 ──
    const hw=~~((ir-il)/2),hh=~~((ib-it)/2),cut=~~(Math.min(hw,hh)*.38);
    for(let y=it;y<ib;y++)for(let x=il;x<ir;x++){
      const dx2=Math.abs(x-cx),dy2=Math.abs(y-cy);
      if(dx2<=hw&&dy2<=hh&&dx2+dy2<=hw+hh-cut)map[y][x]=4;
    }
    const pr2=~~(Math.min(hw,hh)*.5);
    [[-1,-1],[1,-1],[-1,1],[1,1]].forEach(([sx,sy])=>{
      const px=cx+sx*pr2,py=cy+sy*pr2;
      if(py>=0&&py<mh&&px>=0&&px<mw&&map[py][px]===4){map[py][px]=1;if(py+sy>=0&&py+sy<mh)map[py+sy][px]=1}
    });
  }else{// ── 타원형 + 기둥 원 ──
    for(let y=it;y<ib;y++)for(let x=il;x<ir;x++){
      const nx=(x-cx)/((ir-il)/2),ny=(y-cy)/((ib-it)/2);
      if(nx*nx+ny*ny<=1)map[y][x]=4;
    }
    const pr3=~~(Math.min(ir-il,ib-it)*.22);
    for(let i=0;i<6;i++){const a=Math.PI*2*i/6;
      const px=cx+~~(Math.cos(a)*pr3),py=cy+~~(Math.sin(a)*pr3);
      if(py>=0&&py<mh&&px>=0&&px<mw&&map[py][px]===4)map[py][px]=1;
    }
  }
  // 진입 지점 (하단 중앙) 확보
  const entY=ib-3;
  for(let dy=-2;dy<=1;dy++)for(let dx=-3;dx<=3;dx++){
    const ty=entY+dy,tx=cx+dx;if(ty>=0&&ty<mh&&tx>=0&&tx<mw)map[ty][tx]=4;
  }
  // 보스 스폰 지점 (상단 중앙) 확보
  const bossY=it+5;
  for(let dy=-2;dy<=2;dy++)for(let dx=-3;dx<=3;dx++){
    const ty=bossY+dy,tx=cx+dx;if(ty>=0&&ty<mh&&tx>=0&&tx<mw&&map[ty][tx]===1)map[ty][tx]=4;
  }
  // 출구 — 아레나 최상단 바닥 바로 위 벽에 배치 (빈공간 없음)
  let exitY=it;
  for(let y=it;y<cy;y++){if(map[y][cx]===4){exitY=y-1;break;}}
  if(exitY<1)exitY=1;
  const exitX=cx;
  // 출구 타일은 벽으로 유지 — 보스 사망 시 열림 (미리 파지 않음)
  // 아레나 가장자리 — 벽 인접 바닥을 tile=5로 (경계 룬)
  for(let y=it;y<ib;y++)for(let x=il;x<ir;x++){
    if(map[y][x]!==4)continue;
    if((y>0&&map[y-1][x]===1)||(y<mh-1&&map[y+1][x]===1)||(x>0&&map[y][x-1]===1)||(x<mw-1&&map[y][x+1]===1))map[y][x]=5;
  }
  return{map,mw,mh,rooms:[{x:il,y:it,w:ir-il,h:ib-it,cx:cx,cy:cy,type:'boss',cleared:false}],exitX,exitY,entryX:cx,entryY:entY,bossX:cx,bossY};
}

const ARENA_TYPES=['원형','대성당','십자형','팔각형','타원형'];
const mapStore={};
function getMap(sid){
  // floor10(grid 타입)은 격자맵으로 리다이렉트
  const st=STAGES[sid];
  if(st && st.type==='grid') return getGridMap(st.hell);
  if(!mapStore[sid]){
    const r=generateMap(sid);if(!r)return null;
    const{map,mw,mh,rooms,tmpl,gateTiles,exitTiles}=r;
    const grid=[],special=[];
    for(let y=0;y<mh;y++){grid[y]=new Uint8Array(mw);for(let x=0;x<mw;x++){
      const v=map[y][x];
      if(v===0){grid[y][x]=1}
      else if(v===4){grid[y][x]=1} // 보스방은 별도 → 일반바닥 처리
      else if(v===3){grid[y][x]=2;special.push({x,y,type:'gate'})} // 보스문은 유지
      else if(v===2){grid[y][x]=1;special.push({x,y,type:'exit'})}
      else{grid[y][x]=2}
    }}
    const objs=[];
    for(const rm of rooms){
      if(rm.type==='start')objs.push({x:rm.cx,y:rm.cy,id:'player_start'});
      if(rm.type==='forge')objs.push({x:rm.cx,y:rm.cy,id:'forge'});
    }
    if(tmpl.corridorSpawns)for(const sp of tmpl.corridorSpawns)objs.push({x:sp.x,y:sp.y,id:'spawn_g'+(sp.grade||0)});
    for(const rd of tmpl.rooms)if(rd.spawns)for(const sp of rd.spawns)objs.push({x:rd.cx+sp.dx,y:rd.cy+sp.dy,id:'spawn_g'+(sp.grade||0)});
    mapStore[sid]={grid,mw,mh,rooms,objs,special,dirty:true};
  }
  return mapStore[sid];
}
function getBossMap(sid){
  const key=sid+'_boss';
  if(!mapStore[key]){
    const r=genBossArena(sid);
    const grid=[];const special=[];
    for(let y=0;y<r.mh;y++){grid[y]=new Uint8Array(r.mw);for(let x=0;x<r.mw;x++){
      const v=r.map[y][x];
      if(v===4){grid[y][x]=1;special.push({x,y,type:'boss_floor'})}
      else if(v===5){grid[y][x]=1;special.push({x,y,type:'arena_edge'})}
      else{grid[y][x]=2}
    }}
    const objs=[
      {x:r.entryX,y:r.entryY,id:'player_start'},
      {x:r.bossX,y:r.bossY,id:'boss_pos'},
      {x:r.exitX,y:r.exitY,id:'exit'},
    ];
    const rooms=[{cx:~~(r.mw/2),cy:~~(r.mh/2),rx:20,ry:16,type:'boss',id:'boss'}];
    mapStore[key]={grid,mw:r.mw,mh:r.mh,rooms,objs,special,dirty:true};
  }
  return mapStore[key];
}
function getCurrentMapOrig(){return mapMode==='boss'?getBossMap(currentStage):getMap(currentStage)}
function reloadMap(){if(!confirm('원본으로 복원?'))return;const key=mapMode==='boss'?currentStage+'_boss':currentStage;delete mapStore[key];getCurrentMap()}

let currentHell=0,currentStage=0,currentHeight=1,mapMode='normal',brushRadius=5,brushShape='circle';
let selectedObj=null,camX=0,camY=0,zoom=0.5;
let dragging=false,lastMX=0,lastMY=0,painting=false,hoverTX=0,hoverTY=0;
let undoStack=[],boxStart=null;

function setMapModeOrig(mode){
  mapMode=mode;
  document.getElementById('mode-normal').style.background=mode==='normal'?'#222':'#1a1a1a';
  document.getElementById('mode-normal').style.color=mode==='normal'?'#ffea00':'#888';
  document.getElementById('mode-normal').style.borderBottom=mode==='normal'?'2px solid #ffea00':'2px solid transparent';
  document.getElementById('mode-boss').style.background=mode==='boss'?'#2a0000':'#1a1a1a';
  document.getElementById('mode-boss').style.color=mode==='boss'?'#ff4400':'#888';
  document.getElementById('mode-boss').style.borderBottom=mode==='boss'?'2px solid #ff4400':'2px solid transparent';
  loadStage(currentStage);
}
function setHeight(h){currentHeight=h;selectedObj=null;for(let i=0;i<=3;i++)document.getElementById('th'+i).classList.toggle('active',i===h);document.querySelectorAll('.obj-btn').forEach(b=>b.classList.remove('active'));saveEditorSettings(false)}
function setBrush(s){brushShape=s;boxStart=null;document.getElementById('bs-c').classList.toggle('active',s==='circle');document.getElementById('bs-r').classList.toggle('active',s==='rect');document.getElementById('bs-b').classList.toggle('active',s==='box');saveEditorSettings(false)}
function markDirty(){const m=getCurrentMap();if(m)m.dirty=true}

function applyBrush(cx,cy){
  const m=getCurrentMap();if(!m)return;
  if(selectedObj){if(cx>=0&&cy>=0&&cx<m.mw&&cy<m.mh){
    m.objs=m.objs.filter(o=>!(Math.abs(o.x-cx)<3&&Math.abs(o.y-cy)<3));
    if(selectedObj!=='_delete')m.objs.push({x:cx,y:cy,id:selectedObj});_scheduleMapAutosave()}return}
  const r=brushRadius;
  for(let dy=-r;dy<=r;dy++)for(let dx=-r;dx<=r;dx++){
    if(brushShape==='circle'&&dx*dx+dy*dy>r*r)continue;
    const tx=cx+dx,ty=cy+dy;if(tx>=0&&ty>=0&&tx<m.mw&&ty<m.mh)m.grid[ty][tx]=currentHeight;
  }
  m.dirty=true;
  _scheduleMapAutosave();
}
function applyBox(x1,y1,x2,y2){
  const m=getCurrentMap();if(!m)return;
  const sx=Math.max(0,Math.min(x1,x2)),sy=Math.max(0,Math.min(y1,y2)),ex=Math.min(m.mw-1,Math.max(x1,x2)),ey=Math.min(m.mh-1,Math.max(y1,y2));
  for(let y=sy;y<=ey;y++)for(let x=sx;x<=ex;x++)m.grid[y][x]=currentHeight;m.dirty=true;
  _scheduleMapAutosave();
}
function smoothEdges(){
  saveUndo();const m=getCurrentMap();if(!m)return;
  const tmp=[];for(let y=0;y<m.mh;y++){tmp[y]=new Uint8Array(m.mw);for(let x=0;x<m.mw;x++)tmp[y][x]=m.grid[y][x]}
  for(let y=1;y<m.mh-1;y++)for(let x=1;x<m.mw-1;x++){let s=0;for(let dy=-1;dy<=1;dy++)for(let dx=-1;dx<=1;dx++)s+=m.grid[y+dy][x+dx];tmp[y][x]=Math.round(s/9)}
  for(let y=0;y<m.mh;y++)for(let x=0;x<m.mw;x++)m.grid[y][x]=tmp[y][x];m.dirty=true;
  _scheduleMapAutosave();
}
function buildObjPalette(){
  const pal=document.getElementById('obj-palette');pal.innerHTML='';let lc='';
  for(const d of OBJ_DEFS){
    if(d.cat!==lc){lc=d.cat;const h=document.createElement('div');h.style.cssText='color:#555;font-size:9px;margin-top:3px';h.textContent=lc;pal.appendChild(h)}
    const b=document.createElement('div');b.className='obj-btn';b.dataset.id=d.id;b.title=d.name;b.style.background=d.color+'22';
    b.onclick=()=>{selectedObj=d.id;document.querySelectorAll('.obj-btn').forEach(x=>x.classList.toggle('active',x.dataset.id===d.id));for(let i=0;i<=3;i++)document.getElementById('th'+i).classList.remove('active')};
    if(d.img){b.innerHTML=`<img src="${d.img}" style="width:36px;height:36px;image-rendering:pixelated"><div class="label">${d.name}</div>`}
    else{b.innerHTML=`<span style="font-size:18px">${d.icon}</span><div class="label">${d.name}</div>`}
    pal.appendChild(b);
  }
}
buildObjPalette();
function buildChapterTabs(){
  const ct=document.getElementById('chapter-tabs');ct.innerHTML='';
  HELLS.forEach((h,i)=>{const b=document.createElement('div');b.className='ch-tab'+(i===currentHell?' active':'');
    if(i===currentHell){b.style.background=h.color;b.style.color='#000';b.style.borderColor=h.color}
    b.textContent=(i+1)+'장';b.onclick=()=>{currentHell=i;buildChapterTabs();buildStageListOrig()};ct.appendChild(b)})
}
function buildStageListOrig(){
  const sl=document.getElementById('stage-list');sl.innerHTML='';
  const ch=CHAPTER_STAGES[currentHell];if(!ch)return;
  for(let i=ch.startSi;i<ch.startSi+ch.stages;i++){const s=STAGES[i];
    if(!s)continue;
    const item=document.createElement('div');item.className='stage-item'+(i===currentStage?' active':'');
    const bossType=ARENA_TYPES[i%5];
    item.innerHTML=mapMode==='boss'?
      `<div><div class="name">${s.floor}층 보스방</div><div class="size">50×42 [${bossType}]</div></div><div class="badge" style="background:#ff4400">💀</div>`:
      `<div><div class="name">${s.floor}층 <span style="font-size:9px;color:#888">${s.type==='horiz'?'↔가로':s.type==='grid'?'🔲격자':'🗺️맵'}</span></div><div class="size">${s.mw}×${s.mh}</div></div><div class="badge" style="background:${s.type==='grid'?'#ff4400':s.type==='horiz'?'#0088ff':HELLS[s.hell].color}">${s.type==='grid'?'👑':s.type==='horiz'?'↔':'🗺️'}</div>`;
    item.onclick=()=>loadStage(i);sl.appendChild(item)}
}
function loadStage(sid){
  if(sid<0||sid>=STAGES.length)sid=0;
  currentStage=sid;const s=STAGES[sid],m=getMap(sid);if(!m)return;
  camX=m.mw*T/2;camY=m.mh*T/2;zoom=Math.min(editor.clientWidth/(m.mw*T+100),editor.clientHeight/(m.mh*T+100),1);
  undoStack=[];buildStageListOrig();
  document.getElementById('stage-label').textContent=mapMode==='boss'?`${HELLS[s.hell].name} — ${s.floor}층 보스방 [${ARENA_TYPES[sid%5]}] (${m.mw}×${m.mh})`:`${HELLS[s.hell].name} — ${s.floor}층 (${m.mw}×${m.mh})`;
  document.getElementById('stage-label').style.color=HELLS[s.hell].color;
  document.getElementById('room-info').textContent='방: '+m.rooms.map(r=>`${r.id}(${r.type})`).join(' → ');
  saveEditorSettings(false);
}
function resize(){C.width=editor.clientWidth;C.height=editor.clientHeight}
resize();window.onresize=resize;
function mouseToTile(mx,my){const wx=(mx-C.width/2)/zoom+camX,wy=(my-C.height/2)/zoom+camY;return{tx:Math.floor(wx/T),ty:Math.floor(wy/T)}}
function saveUndo(){const m=getCurrentMap();if(!m)return;undoStack.push({grid:m.grid.map(r=>new Uint8Array(r)),objs:JSON.parse(JSON.stringify(m.objs))});if(undoStack.length>40)undoStack.shift()}
function undo(){if(!undoStack.length)return;const m=getCurrentMap(),s=undoStack.pop();for(let y=0;y<m.mh;y++)m.grid[y]=s.grid[y];m.objs=s.objs;m.dirty=true;_scheduleMapAutosave()}

C.onmousedown=e=>{
  if(e.button===1||e.button===2){dragging=true;lastMX=e.clientX;lastMY=e.clientY;e.preventDefault();return}
  if(e.button===0){saveUndo();const{tx,ty}=mouseToTile(e.offsetX,e.offsetY);if(brushShape==='box'){boxStart={tx,ty};return}painting=true;applyBrush(tx,ty)}
};
C.onmousemove=e=>{const{tx,ty}=mouseToTile(e.offsetX,e.offsetY);hoverTX=tx;hoverTY=ty;
  if(dragging){camX-=(e.clientX-lastMX)/zoom;camY-=(e.clientY-lastMY)/zoom;lastMX=e.clientX;lastMY=e.clientY}
  if(painting)applyBrush(tx,ty)};
C.onmouseup=e=>{if(e.button===1||e.button===2)dragging=false;
  if(e.button===0){painting=false;if(boxStart&&brushShape==='box'){const{tx,ty}=mouseToTile(e.offsetX,e.offsetY);applyBox(boxStart.tx,boxStart.ty,tx,ty);boxStart=null} _saveLiveMapState(); }};
C.oncontextmenu=e=>e.preventDefault();
C.onwheel=e=>{const old=zoom;zoom*=e.deltaY<0?1.15:0.87;zoom=Math.max(.1,Math.min(6,zoom));camX+=(e.offsetX-C.width/2)*(1/old-1/zoom);camY+=(e.offsetY-C.height/2)*(1/old-1/zoom);e.preventDefault()};
window.onkeydown=e=>{if(e.target.tagName==='INPUT')return;
  if(e.key>='0'&&e.key<='3')setHeight(+e.key);
  if(e.key==='c')setBrush('circle');if(e.key==='s')setBrush('rect');if(e.key==='b')setBrush('box');
  if(e.key==='['){brushRadius=Math.max(1,brushRadius-1);document.getElementById('brushR').value=brushRadius;document.getElementById('brVal').textContent=brushRadius}
  if(e.key===']'){brushRadius=Math.min(25,brushRadius+1);document.getElementById('brushR').value=brushRadius;document.getElementById('brVal').textContent=brushRadius}
  if(e.ctrlKey&&e.key==='z'){e.preventDefault();undo()}
  if(e.ctrlKey&&e.key.toLowerCase()==='s'){
    e.preventDefault();
    if(e.shiftKey){ saveSettingsAsFile(); }
    else { saveEditorSettings(true); }
  }};

function exportCurrent(){
  const s=STAGES[currentStage],m=getCurrentMap();if(!m)return;
  const flat=[];for(let y=0;y<m.mh;y++)for(let x=0;x<m.mw;x++)flat.push(m.grid[y][x]);
  const rle=[];let i=0;while(i<flat.length){let v=flat[i],c=1;while(i+c<flat.length&&flat[i+c]===v&&c<255)c++;rle.push(v,c);i+=c}
  const data={version:8,stage:currentStage,hell:s.hell,floor:s.floor,mw:m.mw,mh:m.mh,tileSize:T,heightRle:rle,objects:m.objs,rooms:m.rooms};
  const blob=new Blob([JSON.stringify(data)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`맵_S${currentStage}_${HELLS[s.hell].name}_${s.floor}층.json`;a.click();
}
function exportAll(){
  const all={version:8,stages:{}};
  for(const[sid,m] of Object.entries(mapStore)){const s=STAGES[sid];
    const flat=[];for(let y=0;y<m.mh;y++)for(let x=0;x<m.mw;x++)flat.push(m.grid[y][x]);
    const rle=[];let i=0;while(i<flat.length){let v=flat[i],c=1;while(i+c<flat.length&&flat[i+c]===v&&c<255)c++;rle.push(v,c);i+=c}
    all.stages[sid]={hell:s.hell,floor:s.floor,mw:m.mw,mh:m.mh,heightRle:rle,objects:m.objs,rooms:m.rooms}}
  const blob=new Blob([JSON.stringify(all)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='전체맵.json';a.click();
}
function importAll(){document.getElementById('fileInput').click()}
document.getElementById('fileInput').onchange=function(e){const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();reader.onload=ev=>{try{const data=JSON.parse(ev.target.result);
    function loadOne(id,sd){if(id<0||id>=STAGES.length){console.warn('[IMPORT] 스테이지 '+id+' 범위 초과, 스킵');return}const m=getMap(id);if(!m)return;if(sd.heightRle){let idx=0;
      for(let i=0;i<sd.heightRle.length;i+=2){const v=sd.heightRle[i],c=sd.heightRle[i+1];for(let j=0;j<c&&idx<m.mw*m.mh;j++){m.grid[(idx/m.mw)|0][idx%m.mw]=v;idx++}}}
      if(sd.objects)m.objs=sd.objects;m.dirty=true}
    if(data.stages){for(const[sid,sd] of Object.entries(data.stages))loadOne(+sid,sd);alert('불러오기 완료')}
    else if(data.stage!==undefined){loadOne(data.stage,data);loadStage(data.stage);alert('불러오기 완료')}
    _scheduleMapAutosave();
    buildStageListOrig()}catch(err){alert('오류: '+err.message)}};reader.readAsText(file)};

let rCache=null,rStage=-1;
function buildCache(){
  const m=getCurrentMap();if(!m)return;
  const cv=document.createElement('canvas');cv.width=m.mw*T;cv.height=m.mh*T;const cx=cv.getContext('2d');
  for(let y=0;y<m.mh;y++)for(let x=0;x<m.mw;x++){const h=m.grid[y][x];cx.fillStyle=H_COL[h]||'#000';cx.fillRect(x*T,y*T,T,T)}
  // 보스방/게이트/출구 특수 표시
  if(m.special)for(const sp of m.special){
    const px=sp.x*T,py=sp.y*T;
    if(sp.type==='boss_floor'){cx.fillStyle='rgba(255,0,50,0.08)';cx.fillRect(px,py,T,T)}
    else if(sp.type==='arena_edge'){cx.fillStyle='rgba(255,200,50,0.12)';cx.fillRect(px,py,T,T)}
    else if(sp.type==='gate'){cx.fillStyle='#2a0040';cx.fillRect(px,py,T,T);cx.fillStyle='rgba(180,0,255,0.3)';cx.fillRect(px,py,T,T)}
    else if(sp.type==='exit'){cx.fillStyle='#003a00';cx.fillRect(px,py,T,T);cx.fillStyle='rgba(0,255,100,0.2)';cx.fillRect(px,py,T,T)}
  }
  if(show3d){for(let y=0;y<m.mh;y++)for(let x=0;x<m.mw;x++){const h=m.grid[y][x],px=x*T,py=y*T;
    if(y<m.mh-1){const d=h-m.grid[y+1][x];if(d>0){const ch=Math.min(d*T*3,T*10);
      for(let row=0;row<ch;row++){const dp=row/ch;cx.fillStyle=`rgb(${40+~~((1-dp)*50)},${30+~~((1-dp)*35)},${20+~~((1-dp)*20)})`;cx.fillRect(px,py+T+row,T,1)}
      cx.fillStyle='rgba(200,180,140,0.15)';cx.fillRect(px,py+T,T,1)}}
    if(y>0){const d=m.grid[y-1][x]-h;if(d>0){const sl=Math.min(d*T*2,T*6);
      const sg=cx.createLinearGradient(px,py,px,py+sl);sg.addColorStop(0,`rgba(0,0,0,${0.2+d*0.08})`);sg.addColorStop(1,'rgba(0,0,0,0)');cx.fillStyle=sg;cx.fillRect(px,py,T,sl)}}
  }}
  if(showGrid){cx.strokeStyle='#ffffff05';cx.lineWidth=0.5;
    for(let y=0;y<m.mh;y+=10){cx.beginPath();cx.moveTo(0,y*T);cx.lineTo(m.mw*T,y*T);cx.stroke()}
    for(let x=0;x<m.mw;x+=10){cx.beginPath();cx.moveTo(x*T,0);cx.lineTo(x*T,m.mh*T);cx.stroke()}}
  rCache=cv;rStage=currentStage;
}

let fc=0;
function draw(){
  fc++;const m=getCurrentMap();if(!m){requestAnimationFrame(draw);return}
  if(m.dirty||rStage!==currentStage){buildCache();m.dirty=false}
  X.fillStyle='#030303';X.fillRect(0,0,C.width,C.height);
  X.save();X.translate(C.width/2,C.height/2);X.scale(zoom,zoom);X.translate(-camX,-camY);
  if(rCache)X.drawImage(rCache,0,0);
  if(showRooms){X.font='10px monospace';X.textAlign='center';X.textBaseline='middle';
    for(const r of m.rooms){const l=r.type==='start'?'START':r.type==='boss'?'BOSS':r.type==='forge'?'FORGE':r.id||'';
      if(l){X.fillStyle=r.type==='boss'?'rgba(255,50,50,0.25)':'rgba(255,255,255,0.15)';X.fillText(l,r.cx*T,r.cy*T);
        if(r.type==='boss'){X.strokeStyle='rgba(255,50,50,0.12)';X.lineWidth=1;X.beginPath();X.arc(r.cx*T,r.cy*T,(r.rx||8)*T,0,Math.PI*2);X.stroke()}}}
    // 게이트 라벨
    if(m.special)for(const sp of m.special){
      if(sp.type==='gate'){X.fillStyle='rgba(180,0,255,0.4)';X.font='8px monospace';X.fillText('GATE',sp.x*T,sp.y*T-T)}
      if(sp.type==='exit'){X.fillStyle='rgba(0,255,100,0.4)';X.font='8px monospace';X.fillText('EXIT',sp.x*T,sp.y*T+T*2)}
    }}
  if(showObj){for(const o of m.objs){const od=OBJ_DEFS.find(d=>d.id===o.id);if(!od)continue;
    const px=o.x*T,py=o.y*T;
    const im=_objImgs[od.id];
    if(im&&im.complete&&im.naturalWidth>0){
      // 이미지 오브젝트: 실제 PNG 렌더
      const drawSz=(od.sz||32)/32*T*4;
      if(od.sheet){const sh=od.sheet,cw=~~(im.naturalWidth/sh.c),ch=~~(im.naturalHeight/sh.r);
        const si=((~~(o.x*7919+o.y*104729+31))&0x7fffffff)%(sh.c*sh.r);
        X.drawImage(im,(si%sh.c)*cw,~~(si/sh.c)*ch,cw,ch,px-drawSz/2,py-drawSz/2,drawSz,drawSz);
      }else X.drawImage(im,px-drawSz/2,py-drawSz/2,drawSz,drawSz);
      // 발광버섯: 포인트라이트 미리보기
      if(od.id.startsWith('mushroom_glow')){X.fillStyle='rgba(255,180,80,0.12)';X.beginPath();X.arc(px,py,T*10,0,Math.PI*2);X.fill()}
    }else{
      // 기존 이모지 렌더
      const sz=T*2.5;
      X.fillStyle=od.color+'55';X.beginPath();X.arc(px,py,sz,0,Math.PI*2);X.fill();
      X.strokeStyle=od.color;X.lineWidth=1;X.beginPath();X.arc(px,py,sz,0,Math.PI*2);X.stroke();
      X.font=`${sz*1.2}px serif`;X.textAlign='center';X.textBaseline='middle';X.fillStyle='#fff';X.fillText(od.icon,px,py+1);
    }}}
  if(hoverTX>=0&&hoverTX<m.mw&&hoverTY>=0&&hoverTY<m.mh){
    const hc=HELLS[STAGES[currentStage].hell].color+'44';
    if(selectedObj){X.strokeStyle='#ff880066';X.lineWidth=2;X.beginPath();X.arc(hoverTX*T,hoverTY*T,T*3,0,Math.PI*2);X.stroke()}
    else if(brushShape==='box'&&boxStart){const x1=Math.min(boxStart.tx,hoverTX),y1=Math.min(boxStart.ty,hoverTY),x2=Math.max(boxStart.tx,hoverTX),y2=Math.max(boxStart.ty,hoverTY);
      X.fillStyle=(H_COL[currentHeight]||'#fff')+'44';X.fillRect(x1*T,y1*T,(x2-x1+1)*T,(y2-y1+1)*T);
      X.strokeStyle=HELLS[STAGES[currentStage].hell].color;X.lineWidth=1.5;X.strokeRect(x1*T,y1*T,(x2-x1+1)*T,(y2-y1+1)*T)}
    else if(brushShape==='box'){X.strokeStyle=hc;X.lineWidth=1;X.strokeRect(hoverTX*T,hoverTY*T,T,T)}
    else{X.strokeStyle=hc;X.lineWidth=1;const r=brushRadius;
      if(brushShape==='rect')X.strokeRect((hoverTX-r)*T,(hoverTY-r)*T,r*2*T,r*2*T);
      else{X.beginPath();X.arc(hoverTX*T,hoverTY*T,r*T,0,Math.PI*2);X.stroke()}}}
  X.strokeStyle=HELLS[STAGES[currentStage].hell].color+'22';X.lineWidth=2;X.strokeRect(0,0,m.mw*T,m.mh*T);
  X.restore();
  const ch=(hoverTY>=0&&hoverTY<m.mh&&hoverTX>=0&&hoverTX<m.mw)?m.grid[hoverTY]?.[hoverTX]:'?';
  document.getElementById('hud-text').innerHTML=`<b>${HELLS[STAGES[currentStage].hell].name}</b> ${STAGES[currentStage].floor}층 | [${hoverTX},${hoverTY}] h=${ch}(${H_NAME[ch]||'?'}) | ${selectedObj?OBJ_DEFS.find(d=>d.id===selectedObj)?.name||'':'높이 '+currentHeight}`;
  requestAnimationFrame(draw);
}

// ═══════════════════════════════════════════════════════
// 🔲 격자맵 시스템 — 5열 × 5행 그리드 던전
//    가로로 넓은 맵, 방들이 상하좌우 연결
//    지옥 7개 × 각 1장 (총 7개 격자맵)
// ═══════════════════════════════════════════════════════

const GRID_MAPS = {};
const gridMapStore = {};
const _gridSeeds = {};
let currentGridHell = 0;

// 시드 기반 재현 가능 랜덤
function mkRng(seed) {
  let s = (seed ^ 0x9e3779b9) >>> 0;
  return () => {
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = s ^ (s >>> 16);
    return (s >>> 0) / 0xffffffff;
  };
}

// ── 격자맵 생성 ──
function generateGridMap(hell, forceSeed) {
  if (forceSeed !== undefined) _gridSeeds[hell] = forceSeed;
  else if (_gridSeeds[hell] === undefined) _gridSeeds[hell] = hell * 3571 + 42;
  const rng = mkRng(_gridSeeds[hell]);

  const COLS = 5, ROWS = 5;
  const sc = 1 + hell * 0.20;
  const roomRx = Math.round(8 * sc);    // 방 반지름 X
  const roomRy = Math.round(6 * sc);    // 방 반지름 Y
  const corrW = Math.max(5, Math.round(5 * sc));
  const pad = 3;  // 맵 끝 최소 여백 (벽 1~2타일)

  // 셀 크기 = 맵 전체를 COLS×ROWS로 균등 분할
  const mw = COLS * Math.round(24 * sc) + pad * 2;
  const mh = ROWS * Math.round(20 * sc) + pad * 2;
  const cellW = Math.round((mw - pad * 2) / COLS);
  const cellH = Math.round((mh - pad * 2) / ROWS);

  // ── 방 배치 (각 셀 중심 + 지터) ──
  const cells = [];
  for (let row = 0; row < ROWS; row++) {
    cells[row] = [];
    for (let col = 0; col < COLS; col++) {
      const baseCx = pad + col * cellW + Math.round(cellW / 2);
      const baseCy = pad + row * cellH + Math.round(cellH / 2);
      const jx = Math.round((rng() - 0.5) * cellW * 0.28);
      const jy = Math.round((rng() - 0.5) * cellH * 0.28);
      const cx = Math.max(roomRx + 3, Math.min(mw - roomRx - 3, baseCx + jx));
      const cy = Math.max(roomRy + 3, Math.min(mh - roomRy - 3, baseCy + jy));

      // 타입: start/forge만 결정 — 보스는 BFS 후 배정
      let type = 'combat';
      const midCol = Math.floor(COLS / 2);
      const midRow = Math.floor(ROWS / 2);
      if (row === ROWS - 1 && col === midCol) type = 'start';
      else if (row === midRow && col === midCol) type = 'forge';
      else if (rng() < 0.07) type = 'forge';

      // 방 형태
      const shapes = ['ellipse', 'circle', 'rect', 'cross'];
      const shape = type === 'forge' ? 'rect'
                  : type === 'boss'  ? 'circle'
                  : shapes[Math.floor(rng() * shapes.length)];

      const rx = Math.max(5, Math.round(roomRx + (rng() - 0.5) * roomRx * 0.45));
      const ry = Math.max(4, Math.round(roomRy + (rng() - 0.5) * roomRy * 0.45));

      // 스폰
      const grade = Math.min(3, hell > 0 ? Math.floor(hell * 0.5 + rng() * 1.5) : Math.floor(rng() * 1.5));
      const spawns = (type === 'combat') ? [
        { dx: Math.round((rng()-0.5)*rx*0.9), dy: Math.round((rng()-0.5)*ry*0.7), grade },
        { dx: Math.round((rng()-0.5)*rx*0.9), dy: Math.round((rng()-0.5)*ry*0.7), grade },
      ] : undefined;

      const id = type === 'start' ? 's'
               : type === 'boss'  ? 'b'
               : `${type[0]}${row}_${col}`;

      cells[row][col] = { cx, cy, type, shape, rx, ry, spawns, id };
    }
  }

  // ── 연결 (상하좌우 — 일부 랜덤 제거로 미로감) ──
  const corridors = [];
  for (let row = 0; row < ROWS; row++) {
    for (let col = 0; col < COLS; col++) {
      const a = cells[row][col];

      // 오른쪽 연결
      if (col < COLS - 1) {
        // 외곽 행은 거의 다 연결, 내부는 20% 스킵
        const skip = (row === 0 || row === ROWS-1) ? 0.04 : 0.22;
        if (rng() > skip) {
          const b = cells[row][col + 1];
          const midX = Math.round((a.cx + b.cx) / 2);
          const midY = Math.round((a.cy + b.cy) / 2 + (rng()-0.5) * corrW * 1.8);
          corridors.push({ from:a.id, to:b.id, width:corrW, style:'cave', waypoints:[{x:midX,y:midY}] });
        }
      }

      // 아래쪽 연결
      if (row < ROWS - 1) {
        const skip = (col === 0 || col === COLS-1) ? 0.04 : 0.20;
        if (rng() > skip) {
          const b = cells[row + 1][col];
          const midX = Math.round((a.cx + b.cx) / 2 + (rng()-0.5) * corrW * 1.8);
          const midY = Math.round((a.cy + b.cy) / 2);
          corridors.push({ from:a.id, to:b.id, width:corrW, style:'cave', waypoints:[{x:midX,y:midY}] });
        }
      }
    }
  }

  // ── BFS: 시작방에서 가장 먼 구석 → 보스 위치 결정 ──
  {
    // 인접 그래프 빌드
    const adj = {};
    for(let r=0;r<ROWS;r++) for(let cl=0;cl<COLS;cl++) adj[`${r}_${cl}`]=[];
    for(const cd of corridors){
      // id 형태: 's', 'f', 'cR_C' 또는 'r_R_C' 등 → row/col 역산
      const getId = id => {
        if(id==='s') return [ROWS-1, Math.floor(COLS/2)];
        const m=id.match(/^[a-z](\d+)_(\d+)$/);
        return m?[parseInt(m[1]),parseInt(m[2])]:null;
      };
      const a=getId(cd.from), b=getId(cd.to);
      if(a&&b){ adj[`${a[0]}_${a[1]}`].push(b); adj[`${b[0]}_${b[1]}`].push(a); }
    }
    // BFS from start
    const startR=ROWS-1, startC=Math.floor(COLS/2);
    const dist={};
    const queue=[[startR,startC]];
    dist[`${startR}_${startC}`]=0;
    while(queue.length){
      const [r,cl]=queue.shift();
      for(const [nr,nc] of (adj[`${r}_${cl}`]||[])){
        const k=`${nr}_${nc}`;
        if(dist[k]===undefined){ dist[k]=dist[`${r}_${cl}`]+1; queue.push([nr,nc]); }
      }
    }
    // 가장 먼 셀 선택 (같은 거리면 구석 우선 — 맵 끝에 가까운 셀)
    let bestDist=-1, bestR=0, bestC=0;
    for(let r=0;r<ROWS;r++) for(let cl=0;cl<COLS;cl++){
      const k=`${r}_${cl}`;
      const d=dist[k]??0;
      const corner=(r===0||r===ROWS-1?1:0)+(cl===0||cl===COLS-1?1:0); // 구석보너스
      const score=d*10+corner;
      if(score>bestDist && cells[r][cl].type==='combat'){
        bestDist=score; bestR=r; bestC=cl;
      }
    }
    cells[bestR][bestC].type='boss';
    cells[bestR][bestC].id='b';
    cells[bestR][bestC].shape='circle';
  }

  // ── rooms 배열 평탄화 ──
  const rooms = [];
  for (let row = 0; row < ROWS; row++) {
    for (let col = 0; col < COLS; col++) {
      const c = cells[row][col];
      const rd = { id:c.id, type:c.type, cx:c.cx, cy:c.cy, shape:c.shape, rx:c.rx, ry:c.ry };
      if (c.spawns) rd.spawns = c.spawns;
      if (c.shape === 'cross') { rd.armW = Math.round(c.rx*0.55); rd.armH = Math.round(c.ry*0.5); }
      if (c.type === 'boss') {
        const po = Math.round(c.rx * 0.5);
        rd.pillars = [
          {dx:-po, dy:-Math.round(c.ry*0.5), w:3,h:3}, {dx:po, dy:-Math.round(c.ry*0.5), w:3,h:3},
          {dx:-po, dy: Math.round(c.ry*0.5), w:3,h:3}, {dx:po, dy: Math.round(c.ry*0.5), w:3,h:3},
        ];
      }
      rooms.push(rd);
    }
  }

  // ── 알코브 & 스폰 ──
  const features = [];
  const corridorSpawns = [];
  for (let i = 0; i < 8 + hell; i++) {
    features.push({ type:'alcove',
      x: Math.max(3, Math.min(mw-3, Math.round(pad + rng()*(mw-pad*2)))),
      y: Math.max(3, Math.min(mh-3, Math.round(pad + rng()*(mh-pad*2)))),
      r: Math.max(3, Math.round(3 + rng()*6 + hell*0.3))
    });
  }
  for (let i = 0; i < 4 + hell; i++) {
    corridorSpawns.push({
      x: Math.max(2, Math.min(mw-2, Math.round(pad + rng()*(mw-pad*2)))),
      y: Math.max(2, Math.min(mh-2, Math.round(pad + rng()*(mh-pad*2)))),
      grade: Math.min(3, Math.floor(hell * 0.5 + rng() * 2))
    });
  }

  return { mw, mh, rooms, corridors, features, corridorSpawns, _hell:hell, _isGrid:true };
}

// ── 격자맵 → 렌더 캐시 변환 ──
function buildGridMapCache(tmpl) {
  const { mw, mh } = tmpl;
  const map = [];
  for (let y = 0; y < mh; y++) { map[y] = []; for (let x = 0; x < mw; x++) map[y][x] = 1; }

  // 방 카빙
  for (const rd of tmpl.rooms) {
    const { cx, cy, shape, rx, ry } = rd;
    if (shape === 'ellipse') _tCarveEllipse(map,mw,mh,cx,cy,rx,ry||rx);
    else if (shape === 'circle') _tCarveCircle(map,mw,mh,cx,cy,rx);
    else if (shape === 'rect') _tCarveRect(map,mw,mh,cx,cy,rx,ry||rx);
    else if (shape === 'cross') _tCarveCross(map,mw,mh,cx,cy,rx,ry||rx,rd.armW||~~(rx*.5),rd.armH||~~((ry||rx)*.5));
    if (rd.pillars) for (const p of rd.pillars) {
      for (let dy = 0; dy < (p.h||2); dy++) for (let dx = 0; dx < (p.w||2); dx++) {
        const tx=cx+p.dx+dx, ty=cy+p.dy+dy;
        if (tx>0&&tx<mw-1&&ty>0&&ty<mh-1) map[ty][tx]=1;
      }
    }
  }

  // 복도 카빙
  for (const cd of tmpl.corridors) {
    const f = tmpl.rooms.find(r => r.id === cd.from);
    const t = tmpl.rooms.find(r => r.id === cd.to);
    if (!f || !t) continue;
    const pts = [{ x:f.cx, y:f.cy }];
    if (cd.waypoints) for (const wp of cd.waypoints) pts.push(wp);
    pts.push({ x:t.cx, y:t.cy });
    for (let i = 0; i < pts.length-1; i++)
      _tCarveCorridor(map,mw,mh, pts[i].x,pts[i].y, pts[i+1].x,pts[i+1].y, cd.width||4, cd.style||'cave');
  }

  // 알코브
  if (tmpl.features) for (const ft of tmpl.features)
    if (ft.type === 'alcove') _tCarveCircle(map,mw,mh,ft.x,ft.y,ft.r||3);

  _tCaveSmooth(map,mw,mh,1);

  // 보스방 타일 처리
  const bossRd = tmpl.rooms.find(r => r.type === 'boss');
  const special = [];
  if (bossRd) {
    const { cx:bCx, cy:bCy, rx:bRx, ry:bRy } = bossRd;
    const bRyVal = bRy || bRx;
    for (let y=bCy-bRyVal; y<=bCy+bRyVal; y++) for (let x=bCx-bRx; x<=bCx+bRx; x++)
      if (y>0&&y<mh-1&&x>0&&x<mw-1&&map[y][x]===0) map[y][x]=4;

    // 4방향 중 보스방 중심에서 가장 가까운 벽으로 게이트
    const dTop = bCy - bRyVal;
    const dBot = mh - 1 - (bCy + bRyVal);
    const dLeft = bCx - bRx;
    const dRight = mw - 1 - (bCx + bRx);
    const minD = Math.min(dTop, dBot, dLeft, dRight);

    if (minD === dTop) {
      // 12시
      for (let gy=0; gy<dTop+1; gy++)
        for (let gx=bCx-1; gx<=bCx+1; gx++)
          if (gx>=0&&gx<mw&&gy<mh) map[gy][gx]=0;
      for (let gx=bCx-1; gx<=bCx+1; gx++) if(gx>=0&&gx<mw){ map[0][gx]=3; special.push({x:gx,y:0,type:'gate'}); }
      for (let gx=bCx-1; gx<=bCx+1; gx++) if(gx>=0&&gx<mw&&mh>1){ map[1][gx]=2; special.push({x:gx,y:1,type:'exit'}); }
    } else if (minD === dBot) {
      // 6시
      for (let gy=bCy+bRyVal; gy<mh; gy++)
        for (let gx=bCx-1; gx<=bCx+1; gx++)
          if (gx>=0&&gx<mw&&gy>=0) map[gy][gx]=0;
      for (let gx=bCx-1; gx<=bCx+1; gx++) if(gx>=0&&gx<mw){ map[mh-1][gx]=3; special.push({x:gx,y:mh-1,type:'gate'}); }
      for (let gx=bCx-1; gx<=bCx+1; gx++) if(gx>=0&&gx<mw&&mh>1){ map[mh-2][gx]=2; special.push({x:gx,y:mh-2,type:'exit'}); }
    } else if (minD === dLeft) {
      // 9시
      for (let gx=0; gx<dLeft+1; gx++)
        for (let gy=bCy-1; gy<=bCy+1; gy++)
          if (gy>=0&&gy<mh&&gx<mw) map[gy][gx]=0;
      for (let gy=bCy-1; gy<=bCy+1; gy++) if(gy>=0&&gy<mh){ map[gy][0]=3; special.push({x:0,y:gy,type:'gate'}); }
      for (let gy=bCy-1; gy<=bCy+1; gy++) if(gy>=0&&gy<mh&&mw>1){ map[gy][1]=2; special.push({x:1,y:gy,type:'exit'}); }
    } else {
      // 3시
      for (let gx=bCx+bRx; gx<mw; gx++)
        for (let gy=bCy-1; gy<=bCy+1; gy++)
          if (gy>=0&&gy<mh&&gx>=0) map[gy][gx]=0;
      for (let gy=bCy-1; gy<=bCy+1; gy++) if(gy>=0&&gy<mh){ map[gy][mw-1]=3; special.push({x:mw-1,y:gy,type:'gate'}); }
      for (let gy=bCy-1; gy<=bCy+1; gy++) if(gy>=0&&gy<mh&&mw>1){ map[gy][mw-2]=2; special.push({x:mw-2,y:gy,type:'exit'}); }
    }
  }

  // grid 변환
  const grid = [];
  for (let y=0; y<mh; y++) {
    grid[y] = new Uint8Array(mw);
    for (let x=0; x<mw; x++) {
      const v = map[y][x];
      if (v===0||v===4) grid[y][x]=1;
      else if (v===3) { grid[y][x]=2; }
      else if (v===2) { grid[y][x]=1; }
      else grid[y][x]=2;
    }
  }

  // 오브젝트
  const objs = [];
  for (const rm of tmpl.rooms) {
    if (rm.type==='start') objs.push({x:rm.cx,y:rm.cy,id:'player_start'});
    if (rm.type==='forge') objs.push({x:rm.cx,y:rm.cy,id:'forge'});
  }
  if (tmpl.corridorSpawns) for (const sp of tmpl.corridorSpawns) objs.push({x:sp.x,y:sp.y,id:'spawn_g'+(sp.grade||0)});
  for (const rd of tmpl.rooms) if (rd.spawns) for (const sp of rd.spawns) objs.push({x:rd.cx+sp.dx,y:rd.cy+sp.dy,id:'spawn_g'+(sp.grade||0)});

  return { grid, mw, mh, rooms:tmpl.rooms, objs, special, dirty:true };
}

function getGridMap(hell) {
  if (!gridMapStore[hell]) {
    if (!GRID_MAPS[hell]) return null;
    gridMapStore[hell] = buildGridMapCache(GRID_MAPS[hell]);
  }
  return gridMapStore[hell];
}

// ── 격자맵 로드 ──
function loadGridStage(hell) {
  currentGridHell = hell;
  const m = getGridMap(hell); if (!m) return;
  camX = m.mw*T/2; camY = m.mh*T/2;
  zoom = Math.min(editor.clientWidth/(m.mw*T+80), editor.clientHeight/(m.mh*T+80), 1.2);
  undoStack = [];
  buildGridStageList();
  document.getElementById('stage-label').textContent =
    `🔲 격자맵 — ${HELLS[hell].name}  (${m.mw}×${m.mh})  5열×5행 25방`;
  document.getElementById('stage-label').style.color = HELLS[hell].color;
  document.getElementById('room-info').textContent =
    `방 ${m.rooms.length}개 | 격자 5×5 | 시작:하단중앙  보스:상단중앙  대장간:정중앙`;
  saveEditorSettings(false);
}

function buildGridStageList() {
  const sl = document.getElementById('stage-list'); sl.innerHTML='';
  HELLS.forEach((h,i)=>{
    const m = GRID_MAPS[i];
    const item = document.createElement('div');
    item.className = 'stage-item' + (i===currentGridHell?' active':'');
    item.innerHTML = `<div>
      <div class="name">${h.name}</div>
      <div class="size">${m ? m.mw+'×'+m.mh : '미생성'}</div>
    </div><div class="badge" style="background:${h.color};color:#000">5×5</div>`;
    item.onclick = ()=>{ currentGridHell=i; loadGridStage(i); };
    sl.appendChild(item);
  });
}

// ── setMapMode 재정의 ──
function setMapMode(mode) {
  mapMode = mode;
  const styles = {
    'normal':{ el:'mode-normal', bg:'#222',    col:'#ffea00', bor:'#ffea00' },
    'grid'  :{ el:'mode-grid',   bg:'#001a2a', col:'#44ddff', bor:'#44ddff' },
    'boss'  :{ el:'mode-boss',   bg:'#2a0000', col:'#ff4400', bor:'#ff4400' },
  };
  ['normal','grid','boss'].forEach(m=>{
    const el=document.getElementById(styles[m].el); if(!el)return;
    if(m===mode){ el.style.background=styles[m].bg; el.style.color=styles[m].col; el.style.borderBottom=`2px solid ${styles[m].bor}`; }
    else { el.style.background='#1a1a1a'; el.style.color='#888'; el.style.borderBottom='2px solid transparent'; }
  });
  if (mode==='grid') { buildGridStageList(); loadGridStage(currentGridHell); }
  else if (mode==='boss') { buildStageListOrig(); loadStage(currentStage); }
  else { buildStageListOrig(); loadStage(currentStage); }
  saveEditorSettings(false);
}

// ── getCurrentMap 재정의 ──
function getCurrentMap() {
  if (mapMode==='grid') return getGridMap(currentGridHell);
  if (mapMode==='boss') return getBossMap(currentStage);
  return getMap(currentStage);
}

const EDITOR_SETTINGS_KEY_PREFIX='tilemap_editor_settings_v1_slot_';
const EDITOR_SETTINGS_SLOT_KEY='tilemap_editor_selected_slot_v1';
const LIVE_MAP_KEY_PREFIX='tilemap_editor_livemap_v1_slot_';
const LIVE_MAP_INDEX_KEY_PREFIX='tilemap_editor_livemap_index_v1_slot_';
const LIVE_MAP_ENTRY_KEY_PREFIX='tilemap_editor_livemap_entry_v1_slot_';
const BUILD_STAMP='2026-03-06 16:10';
let settingsDirHandle=null;
let settingsFileHandle=null;
let _mapAutosaveTimer=null;
function _slotInput(){ return document.getElementById('settings-slot'); }
function _normalizeSlot(v){
  const n=~~Number(v);
  if(!Number.isFinite(n)) return 1;
  return Math.max(1,Math.min(9,n));
}
function _getSelectedSlot(){
  const el=_slotInput();
  return _normalizeSlot(el?el.value:1);
}
function _setSelectedSlot(slot){
  const s=_normalizeSlot(slot);
  const el=_slotInput(); if(el) el.value=String(s);
  try{ localStorage.setItem(EDITOR_SETTINGS_SLOT_KEY,String(s)); }catch(e){}
  return s;
}
function _settingsKey(slot){ return EDITOR_SETTINGS_KEY_PREFIX + _normalizeSlot(slot); }
function _liveMapKey(slot){ return LIVE_MAP_KEY_PREFIX + _normalizeSlot(slot); }
function _liveMapIndexKey(slot){ return LIVE_MAP_INDEX_KEY_PREFIX + _normalizeSlot(slot); }
function _liveMapEntryKey(slot,mapKey){ return LIVE_MAP_ENTRY_KEY_PREFIX + _normalizeSlot(slot) + '_' + String(mapKey); }
function _settingsFilename(slot){ return `settings_slot_${_normalizeSlot(slot)}.json`; }
function _editorSettingsSnapshot(){
  return {
    mapMode,currentHell,currentStage,currentGridHell,
    currentHeight,brushRadius,brushShape,
    show3d,showObj,showRooms,showGrid
  };
}
function _captureCurrentMapState(){
  const m=getCurrentMap(); if(!m||!m.grid||!m.mw||!m.mh) return null;
  const st=STAGES[currentStage];
  const isGridContext = (mapMode==='grid') || (mapMode!=='boss' && st && st.type==='grid');
  const effectiveGridHell = isGridContext ? (mapMode==='grid' ? currentGridHell : st.hell) : currentGridHell;
  const flat=[];
  for(let y=0;y<m.mh;y++) for(let x=0;x<m.mw;x++) flat.push(~~(m.grid[y]?.[x]||0));
  const rle=[];
  for(let i=0;i<flat.length;){
    const v=flat[i]; let c=1;
    while(i+c<flat.length && flat[i+c]===v && c<65535) c++;
    rle.push(v,c); i+=c;
  }
  const key = mapMode==='boss' ? (currentStage+'_boss') : (isGridContext ? ('grid_'+effectiveGridHell) : String(currentStage));
  return {
    version:1,
    key,
    mode:mapMode,
    stage:currentStage,
    gridHell:effectiveGridHell,
    mw:m.mw,mh:m.mh,rle,
    rooms:Array.isArray(m.rooms)?m.rooms:[],
    objs:Array.isArray(m.objs)?m.objs:[],
    special:Array.isArray(m.special)?m.special:[]
  };
}
function _restoreCurrentMapState(state){
  if(!state||!Array.isArray(state.rle)||!state.mw||!state.mh) return false;
  const mw=~~state.mw,mh=~~state.mh;
  const grid=[];
  for(let y=0;y<mh;y++) grid[y]=new Uint8Array(mw);
  let idx=0;
  for(let i=0;i<state.rle.length;i+=2){
    const v=~~state.rle[i], c=Math.max(0,~~state.rle[i+1]);
    for(let j=0;j<c&&idx<mw*mh;j++,idx++){
      const y=(idx/mw)|0, x=idx%mw;
      grid[y][x]=v;
    }
  }
  const key = (state.key!==undefined && state.key!==null) ? String(state.key) :
    (state.mode==='boss' ? (state.stage+'_boss') : (state.mode==='grid' ? ('grid_'+state.gridHell) : String(state.stage)));
  const isGridKey = key.startsWith('grid_');
  const target={
    grid,mw,mh,
    rooms:Array.isArray(state.rooms)?state.rooms:[],
    objs:Array.isArray(state.objs)?state.objs:[],
    special:Array.isArray(state.special)?state.special:[],
    dirty:true
  };
  if(isGridKey){
    const hellFromKey=Number(key.slice(5));
    const h=Number.isFinite(hellFromKey)?Math.max(0,Math.min(6,~~hellFromKey)):Math.max(0,Math.min(6,~~(state.gridHell||0)));
    gridMapStore[h]=target;
  }else{
    mapStore[key]=target;
  }
  return true;
}
function _saveLiveMapState(){
  try{
    const slot=_getSelectedSlot();
    const live=_captureCurrentMapState();
    if(live){
      // 하위호환: 마지막 편집 맵 1개 키
      localStorage.setItem(_liveMapKey(slot),JSON.stringify(live));
      // 슬롯별 맵 단위 저장
      localStorage.setItem(_liveMapEntryKey(slot,live.key),JSON.stringify(live));
      const idxKey=_liveMapIndexKey(slot);
      const raw=localStorage.getItem(idxKey);
      const arr=raw?JSON.parse(raw):[];
      const set=new Set(Array.isArray(arr)?arr:[]);
      set.add(String(live.key));
      localStorage.setItem(idxKey,JSON.stringify(Array.from(set)));
    }
    // liveMap 자동저장만 켜져 있어도 로드시 컨텍스트를 복원할 수 있게 세팅 스냅샷도 같이 저장
    localStorage.setItem(_settingsKey(slot),JSON.stringify(_editorSettingsSnapshot()));
    localStorage.setItem(EDITOR_SETTINGS_SLOT_KEY,String(slot));
  }catch(e){}
}
function _scheduleMapAutosave(){
  if(_mapAutosaveTimer)clearTimeout(_mapAutosaveTimer);
  _mapAutosaveTimer=setTimeout(()=>{ _saveLiveMapState(); },60);
}
function _timestampForName(){
  const d=new Date();
  const p=n=>String(n).padStart(2,'0');
  return `${d.getFullYear()}${p(d.getMonth()+1)}${p(d.getDate())}_${p(d.getHours())}${p(d.getMinutes())}${p(d.getSeconds())}`;
}
function _collectSlotLiveMaps(slot){
  const maps={};
  try{
    const idxRaw=localStorage.getItem(_liveMapIndexKey(slot));
    const idx=idxRaw?JSON.parse(idxRaw):[];
    if(Array.isArray(idx)){
      for(const k of idx){
        const raw=localStorage.getItem(_liveMapEntryKey(slot,k));
        if(!raw) continue;
        try{
          const one=JSON.parse(raw);
          if(one&&one.key!==undefined) maps[String(one.key)]=one;
        }catch(e){}
      }
    }
  }catch(e){}
  try{
    const raw=localStorage.getItem(_liveMapKey(slot));
    if(raw){
      const one=JSON.parse(raw);
      if(one&&one.key!==undefined && !maps[String(one.key)]) maps[String(one.key)]=one;
    }
  }catch(e){}
  return maps;
}
function _buildSlotBackupPayload(slot){
  let settings=null;
  try{
    const raw=localStorage.getItem(_settingsKey(slot));
    settings=raw?JSON.parse(raw):null;
  }catch(e){}
  if(!settings) settings=_editorSettingsSnapshot();
  const maps=_collectSlotLiveMaps(slot);
  return {
    version:3,
    type:'tilemap_editor_slot_backup',
    slot,
    savedAt:Date.now(),
    build:BUILD_STAMP,
    settings,
    maps
  };
}
async function _writeBackupToFileHandle(handle,payload){
  const writable=await handle.createWritable();
  await writable.write(JSON.stringify(payload,null,2));
  await writable.close();
}
async function _saveBackupToSameFile(forcePick){
  const slot=_getSelectedSlot();
  const payload=_buildSlotBackupPayload(slot);
  if(!window.showSaveFilePicker){
    return {ok:false,reason:'no_picker'};
  }
  if(forcePick || !settingsFileHandle){
    settingsFileHandle = await window.showSaveFilePicker({
      suggestedName:`tilemap_slot${slot}.json`,
      types:[{description:'JSON',accept:{'application/json':['.json']}}]
    });
  }
  await _writeBackupToFileHandle(settingsFileHandle,payload);
  const name=(settingsFileHandle&&settingsFileHandle.name)?settingsFileHandle.name:`tilemap_slot${slot}.json`;
  return {ok:true,name};
}
async function saveSettingsAsFile(){
  try{
    // 저장 직전에 현재 편집 상태를 먼저 반영
    _saveLiveMapState();
    const slot=_getSelectedSlot();
    const payload=_buildSlotBackupPayload(slot);
    const defName=`tilemap_slot${slot}_${_timestampForName()}.json`;
    if(window.showSaveFilePicker){
      settingsFileHandle = await window.showSaveFilePicker({
        suggestedName:defName,
        types:[{description:'JSON',accept:{'application/json':['.json']}}]
      });
      await _writeBackupToFileHandle(settingsFileHandle,payload);
      document.getElementById('stats').textContent=`파일 저장 완료 (${settingsFileHandle.name||defName})`;
      return;
    }
    // 구형 브라우저 fallback: 다운로드 방식
    const blob=new Blob([JSON.stringify(payload,null,2)],{type:'application/json'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download=defName;
    a.click();
    setTimeout(()=>{ try{ URL.revokeObjectURL(a.href); }catch(e){} },1500);
    document.getElementById('stats').textContent=`파일 저장 완료 (${defName})`;
  }catch(e){
    document.getElementById('stats').textContent='파일 저장 실패';
  }
}
function _mapKeyFromSettingsLike(s){
  if(!s) return null;
  if(s.mapMode==='boss') return String((~~s.currentStage)+'_boss');
  if(s.mapMode==='grid') return 'grid_'+String(~~s.currentGridHell);
  const st=STAGES[~~s.currentStage];
  if(st&&st.type==='grid') return 'grid_'+String(~~st.hell);
  return String(~~s.currentStage);
}
function _persistSlotBackup(slot, settings, mapsObj){
  const s=_normalizeSlot(slot);
  try{
    if(settings) localStorage.setItem(_settingsKey(s), JSON.stringify(settings));
    const idxKey=_liveMapIndexKey(s);
    const oldRaw=localStorage.getItem(idxKey);
    const oldIdx=oldRaw?JSON.parse(oldRaw):[];
    if(Array.isArray(oldIdx)){
      for(const k of oldIdx){
        localStorage.removeItem(_liveMapEntryKey(s,k));
      }
    }
    const keys=[];
    if(mapsObj && typeof mapsObj==='object'){
      for(const [k,v] of Object.entries(mapsObj)){
        if(!v||!Array.isArray(v.rle)||!v.mw||!v.mh) continue;
        const key=String(v.key!==undefined?v.key:k);
        localStorage.setItem(_liveMapEntryKey(s,key), JSON.stringify(v));
        keys.push(key);
      }
    }
    localStorage.setItem(idxKey, JSON.stringify(keys));
    const wantedKey=_mapKeyFromSettingsLike(settings);
    let live=null;
    if(wantedKey && mapsObj && mapsObj[wantedKey]) live=mapsObj[wantedKey];
    if(!live && keys.length>0 && mapsObj) live=mapsObj[keys[0]];
    if(live) localStorage.setItem(_liveMapKey(s), JSON.stringify(live));
    localStorage.setItem(EDITOR_SETTINGS_SLOT_KEY, String(s));
  }catch(e){}
}
function _applyLoadedSettingsObject(s){
  if(!s) return;
  mapMode=(s.mapMode==='normal'||s.mapMode==='grid'||s.mapMode==='boss')?s.mapMode:'normal';
  currentHell=Number.isFinite(s.currentHell)?Math.max(0,Math.min(6,~~s.currentHell)):0;
  currentStage=Number.isFinite(s.currentStage)?Math.max(0,Math.min(34,~~s.currentStage)):0;
  currentGridHell=Number.isFinite(s.currentGridHell)?Math.max(0,Math.min(6,~~s.currentGridHell)):0;
  currentHeight=Number.isFinite(s.currentHeight)?Math.max(0,Math.min(3,~~s.currentHeight)):1;
  brushRadius=Number.isFinite(s.brushRadius)?Math.max(1,Math.min(25,~~s.brushRadius)):5;
  brushShape=(s.brushShape==='circle'||s.brushShape==='rect'||s.brushShape==='box')?s.brushShape:'circle';
  show3d=!!s.show3d; showObj=!!s.showObj; showRooms=!!s.showRooms; showGrid=!!s.showGrid;
}
function loadSettingsFromFile(){
  const el=document.getElementById('settingsFileInput');
  if(!el) return;
  el.value='';
  el.click();
}
document.getElementById('settingsFileInput').onchange=function(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const data=JSON.parse(ev.target.result);
      let slot=_getSelectedSlot();
      let settings=null;
      let maps={};
      if(data && data.type==='tilemap_editor_slot_backup' && data.version>=3){
        slot=_normalizeSlot(data.slot||slot);
        settings=data.settings||null;
        maps=(data.maps&&typeof data.maps==='object')?data.maps:{};
      }else if(data && data.version===2 && data.settings){
        slot=_normalizeSlot(data.slot||slot);
        settings=data.settings||null;
        if(data.liveMap && data.liveMap.key!==undefined) maps[String(data.liveMap.key)]=data.liveMap;
      }else{
        alert('지원하지 않는 세팅 파일 형식');
        return;
      }
      if(!settings) settings=_editorSettingsSnapshot();
      _setSelectedSlot(slot);
      _persistSlotBackup(slot,settings,maps);
      _applyLoadedSettingsObject(settings);
      for(const one of Object.values(maps)){ _restoreCurrentMapState(one); }
      _applyLoadedState();
      _saveLiveMapState();
      document.getElementById('stats').textContent=`파일 세팅 불러오기 완료 (슬롯 ${slot})`;
    }catch(err){
      alert('세팅 파일 불러오기 오류: '+err.message);
    }
  };
  reader.readAsText(file);
};
function _mergeSlotPayload(slot,settings,liveMap){
  return {version:2,slot:_normalizeSlot(slot),savedAt:Date.now(),settings,liveMap};
}
async function pickSettingsFolder(){
  try{
    if(!window.showDirectoryPicker){
      document.getElementById('stats').textContent='이 브라우저는 폴더 저장을 지원하지 않음';
      return false;
    }
    settingsDirHandle = await window.showDirectoryPicker({mode:'readwrite'});
    document.getElementById('stats').textContent='세이브 폴더 선택 완료';
    return true;
  }catch(e){
    document.getElementById('stats').textContent='세이브 폴더 선택 취소/실패';
    return false;
  }
}
async function _writeSettingsFile(slot,dataObj){
  if(!settingsDirHandle) return false;
  const f = await settingsDirHandle.getFileHandle(_settingsFilename(slot),{create:true});
  const w = await f.createWritable();
  await w.write(JSON.stringify(dataObj,null,2));
  await w.close();
  return true;
}
async function _readSettingsFile(slot){
  if(!settingsDirHandle) return null;
  try{
    const f = await settingsDirHandle.getFileHandle(_settingsFilename(slot),{create:false});
    const file = await f.getFile();
    return JSON.parse(await file.text());
  }catch(e){
    return null;
  }
}
async function saveEditorSettings(manual){
  try{
    const slot=_getSelectedSlot();
    const snap=_editorSettingsSnapshot();
    const liveMap=_captureCurrentMapState();
    localStorage.setItem(_settingsKey(slot),JSON.stringify(snap));
    if(liveMap) localStorage.setItem(_liveMapKey(slot),JSON.stringify(liveMap));
    localStorage.setItem(EDITOR_SETTINGS_SLOT_KEY,String(slot));
    let msg=`세팅 저장 완료 (슬롯 ${slot})`;
    if(manual){
      try{
        const r=await _saveBackupToSameFile(false);
        if(r.ok) msg=`같은파일 저장 완료 (${r.name})`;
        else if(r.reason==='no_picker') msg='같은파일 저장 완료 (브라우저 파일저장 미지원: 로컬저장만)';
      }catch(e){
        // 사용자가 파일 선택을 취소한 경우에도 로컬저장은 완료됨
        msg='세팅 저장 완료 (로컬저장, 파일저장은 취소/실패)';
      }
    }
    if(manual)document.getElementById('stats').textContent=msg;
  }catch(e){
    if(manual)document.getElementById('stats').textContent='세팅 저장 실패';
  }
}
function _syncSettingUi(){
  const br=document.getElementById('brushR'); if(br)br.value=String(brushRadius);
  const bv=document.getElementById('brVal'); if(bv)bv.textContent=String(brushRadius);
  const cb=document.querySelectorAll('#show-toggles input[type=\"checkbox\"]');
  if(cb&&cb.length>=4){
    cb[0].checked=!!show3d; cb[1].checked=!!showObj; cb[2].checked=!!showRooms; cb[3].checked=!!showGrid;
  }
  setHeight(currentHeight);
  setBrush(brushShape);
}
function _applyLoadedState(){
  _syncSettingUi();
  buildChapterTabs();
  if(mapMode==='grid'){
    buildGridStageList();
    loadGridStage(currentGridHell);
  }else{
    buildStageListOrig();
    loadStage(currentStage);
  }
  draw();
}
async function loadEditorSettings(manual){
  try{
    const slot=_getSelectedSlot();
    let s=null, liveMap=null;
    if(settingsDirHandle){
      const fp = await _readSettingsFile(slot);
      if(fp && fp.version===2){ s=fp.settings||null; liveMap=fp.liveMap||null; }
      else if(fp){ s=fp; }
    }
    if(!s){
      const raw=localStorage.getItem(_settingsKey(slot));
      if(raw) s=JSON.parse(raw);
    }
    if(!liveMap){
      const rm=localStorage.getItem(_liveMapKey(slot));
      if(rm) liveMap=JSON.parse(rm);
    }
    // 슬롯에 저장된 여러 맵을 먼저 복원
    try{
      const idxRaw=localStorage.getItem(_liveMapIndexKey(slot));
      const idx=idxRaw?JSON.parse(idxRaw):[];
      if(Array.isArray(idx)){
        for(const mapKey of idx){
          const er=localStorage.getItem(_liveMapEntryKey(slot,mapKey));
          if(!er) continue;
          const one=JSON.parse(er);
          _restoreCurrentMapState(one);
        }
      }
    }catch(e){}
    // 세팅이 없더라도 liveMap이 있으면 그 정보로 복원 진행
    if(!s && liveMap){
      s={
        mapMode:(liveMap.mode==='normal'||liveMap.mode==='grid'||liveMap.mode==='boss')?liveMap.mode:'normal',
        currentHell:0,
        currentStage:Number.isFinite(liveMap.stage)?Math.max(0,Math.min(34,~~liveMap.stage)):0,
        currentGridHell:Number.isFinite(liveMap.gridHell)?Math.max(0,Math.min(6,~~liveMap.gridHell)):0,
        currentHeight:1,brushRadius:5,brushShape:'circle',
        show3d:true,showObj:true,showRooms:true,showGrid:true
      };
    }
    if(!s){ if(manual)document.getElementById('stats').textContent=`저장된 세팅 없음 (슬롯 ${slot})`; return false; }
    mapMode=(s.mapMode==='normal'||s.mapMode==='grid'||s.mapMode==='boss')?s.mapMode:'normal';
    currentHell=Number.isFinite(s.currentHell)?Math.max(0,Math.min(6,~~s.currentHell)):0;
    currentStage=Number.isFinite(s.currentStage)?Math.max(0,Math.min(34,~~s.currentStage)):0;
    currentGridHell=Number.isFinite(s.currentGridHell)?Math.max(0,Math.min(6,~~s.currentGridHell)):0;
    currentHeight=Number.isFinite(s.currentHeight)?Math.max(0,Math.min(3,~~s.currentHeight)):1;
    brushRadius=Number.isFinite(s.brushRadius)?Math.max(1,Math.min(25,~~s.brushRadius)):5;
    brushShape=(s.brushShape==='circle'||s.brushShape==='rect'||s.brushShape==='box')?s.brushShape:'circle';
    show3d=!!s.show3d; showObj=!!s.showObj; showRooms=!!s.showRooms; showGrid=!!s.showGrid;
    if(liveMap)_restoreCurrentMapState(liveMap);
    _applyLoadedState();
    localStorage.setItem(EDITOR_SETTINGS_SLOT_KEY,String(slot));
    if(manual)document.getElementById('stats').textContent=`세팅 불러오기 완료 (슬롯 ${slot})`;
    return true;
  }catch(e){
    if(manual)document.getElementById('stats').textContent='세팅 불러오기 실패';
    return false;
  }
}

// ── HUD 오버라이드 ──
const _origDraw = draw;
function drawHudLabel() {
  const m = getCurrentMap(); if(!m) return;
  const ch = (hoverTY>=0&&hoverTY<m.mh&&hoverTX>=0&&hoverTX<m.mw) ? m.grid[hoverTY]?.[hoverTX] : '?';
  if (mapMode==='grid') {
    document.getElementById('hud-text').innerHTML =
      `<b>${HELLS[currentGridHell].name} 격자맵</b> | [${hoverTX},${hoverTY}] h=${ch}(${H_NAME[ch]||'?'}) | ${selectedObj?OBJ_DEFS.find(d=>d.id===selectedObj)?.name||'':'높이 '+currentHeight}`;
  } else {
    document.getElementById('hud-text').innerHTML =
      `<b>${HELLS[STAGES[currentStage].hell].name}</b> ${STAGES[currentStage].floor}층 | [${hoverTX},${hoverTY}] h=${ch}(${H_NAME[ch]||'?'}) | ${selectedObj?OBJ_DEFS.find(d=>d.id===selectedObj)?.name||'':'높이 '+currentHeight}`;
  }
}

// ── 🎲 랜덤 재생성 ──
function regenCurrent() {
  if (mapMode==='grid') {
    if (!confirm(`${HELLS[currentGridHell].name} 격자맵 랜덤 재생성?`)) return;
    const seed = Math.floor(Math.random()*999999);
    GRID_MAPS[currentGridHell] = generateGridMap(currentGridHell, seed);
    delete gridMapStore[currentGridHell];
    loadGridStage(currentGridHell);
    document.getElementById('stats').textContent = `🎲 격자맵 재생성 seed:${seed}`;
  } else {
    if (!confirm(`스테이지 ${currentStage} 랜덤 재생성?`)) return;
    const seed = Math.floor(Math.random()*999999);
    FIXED_MAPS[currentStage] = genSnake(currentStage, seed);
    delete mapStore[currentStage];
    loadStage(currentStage);
    document.getElementById('stats').textContent = `🎲 S${currentStage} 재생성 seed:${seed}`;
  }
}
function regenAll() {
  if (!confirm('맵+격자맵 전체 랜덤 재생성?')) return;
  for(let i=0;i<70;i++){FIXED_MAPS[i]=genSnake(i);delete mapStore[i];}
  for(let h=0;h<7;h++){GRID_MAPS[h]=generateGridMap(h,Math.floor(Math.random()*999999));delete gridMapStore[h];}
  if (mapMode==='grid') loadGridStage(currentGridHell);
  else loadStage(currentStage);
  document.getElementById('stats').textContent='✅ 전체 재생성 완료';
}

// ── 세로 S자 뱀형 생성기 ──
const _sSeeds={};
function genSnake(si,forceSeed){
  const st=STAGES[si];const mw=st.mw,mh=st.mh,hell=st.hell,floor=st.floor;
  if(forceSeed!==undefined)_sSeeds[si]=forceSeed;
  else if(_sSeeds[si]===undefined)_sSeeds[si]=si*7919+1;
  const rng=mkRng(_sSeeds[si]);

  const sc=1+si*0.016;
  const bW=Math.max(6,~~(7*sc));          // 복도 너비
  const arW=Math.max(9,~~(11*sc));         // 방 반지름 X
  const arH=Math.max(6,~~(7*sc));          // 방 반지름 Y
  const boW=Math.max(12,~~(15*sc));        // 보스방 크기
  const seg=Math.min(8,3+floor);           // 구간 수

  // Y 분할 — 보스방이 12시 맵 끝에 바짝 붙음 (tPad 없음)
  const bPad=bW+3;
  const useH=mh-bPad;
  const sH=~~(useH/(seg+2)); // +2: 보스방 공간 포함

  // X 범위 — 맵 좌우 끝 거의 다 씀 (벽 2타일만 여유)
  const xMin=arW+2, xMax=mw-arW-2, xM=~~(mw/2);

  // S자 X 좌표 — 좌끝/우끝을 교차하며 랜덤 위치
  const xs=[];
  let dir=rng()>0.5?1:-1;
  for(let i=0;i<seg;i++){
    // 해당 방향 끝쪽 70~95% 위치에 랜덤 배치
    const reach=0.70+rng()*0.25;
    const base=dir>0 ? ~~(xM+(xMax-xM)*reach) : ~~(xMin+(xM-xMin)*(1-reach));
    const noise=~~((rng()-0.5)*mw*0.08);
    xs.push(Math.max(xMin,Math.min(xMax,base+noise)));
    dir*=-1;
  }

  const rooms=[],corridors=[],features=[],corridorSpawns=[];

  // 시작방 — 하단, 좌우 랜덤
  const sX=Math.max(xMin,Math.min(xMax,xM+~~((rng()-0.5)*mw*0.3)));
  const sY=mh-bPad;
  rooms.push({id:'s',type:'start',cx:sX,cy:sY,shape:'ellipse',rx:~~(bW*1.1),ry:~~(bW*0.7)});
  let pId='s',pX=sX,pY=sY;

  const fAt=Math.max(1,~~(seg*0.38+rng()*seg*0.12));
  let ci=0;
  for(let i=0;i<seg;i++){
    const isF=(i===fAt);
    const id=isF?'f':'r'+(++ci);
    // 방 X: forge는 중앙, 나머지는 S자 끝쪽
    const rX=isF?xM:xs[i];
    const rY=sY-sH*(i+1);
    const aW=isF?~~(bW*0.9):arW+~~(rng()*bW*0.6);
    const aH=isF?~~(bW*0.65):arH+~~(rng()*bW*0.35);
    const sh=isF?'rect':rng()<0.38?'circle':rng()<0.6?'ellipse':'cross';
    const gr=Math.min(3,~~(i/seg*3.5+hell*0.25));
    const sp=isF?undefined:[
      {dx:~~((rng()-0.5)*aW*0.9),dy:~~((rng()-0.5)*aH*0.6),grade:gr},
      {dx:~~((rng()-0.5)*aW*0.9),dy:~~((rng()-0.5)*aH*0.6),grade:gr},
      ...(gr>=2?[{dx:~~((rng()-0.5)*aW*0.7),dy:~~((rng()-0.5)*aH*0.7),grade:Math.min(3,gr+1)}]:[])
    ];
    const rd={id,type:isF?'forge':'combat',cx:rX,cy:rY,shape:sh,rx:aW,ry:aH};
    if(sp)rd.spawns=sp;
    if(sh==='cross'){rd.armW=~~(aW*0.55+rng()*aW*0.2);rd.armH=~~(aH*0.5+rng()*aH*0.2)}
    rooms.push(rd);

    // 복도 웨이포인트 — X 이동 구간에서 맵 가로를 가로질러 꺾임
    const wps=[];
    const wN=1+~~(rng()*2);
    for(let w=1;w<=wN;w++){
      const t=w/(wN+1);
      const wy=~~(pY+(rY-pY)*t);
      // 이동 중간에 현재→목적지 사이에서 살짝 오버슛 (자연스러운 S꺾임)
      const wx=~~(pX+(rX-pX)*t+(rng()-0.5)*Math.abs(pY-rY)*0.28);
      wps.push({x:Math.max(2,Math.min(mw-2,wx)),y:Math.max(2,Math.min(mh-2,wy))});
    }
    const cStyle=_pickCorridorStyle(rng,floor,hell);
    corridors.push({from:pId,to:id,width:bW+~~(rng()*3),style:cStyle,waypoints:wps});

    if(rng()<0.45){
      const sp2=wps[~~(rng()*wps.length)];
      corridorSpawns.push({x:Math.max(2,Math.min(mw-2,sp2.x)),y:Math.max(2,Math.min(mh-2,sp2.y)),grade:Math.max(0,gr-1)});
    }
    // 알코브 — 방 좌우 맵 끝 쪽에
    if(rng()<0.35){
      const sd=rX<xM?-1:1; // 반대쪽 여백에
      const ax=Math.max(2,Math.min(mw-2,rX+sd*(aW+2+~~(rng()*5))));
      features.push({type:'alcove',x:ax,y:Math.max(2,Math.min(mh-2,rY+~~((rng()-0.5)*aH*1.2))),r:3+~~(rng()*6+si*0.04)});
    }
    pId=id;pX=rX;pY=rY;
  }

  // 보스방 — 12시 방향 맵 끝에 중심이 반지름만큼만 내려온 위치
  const bCx=Math.max(boW+2,Math.min(mw-boW-2,xM+~~((rng()-0.5)*mw*0.2)));
  const bR=boW, bRy2=Math.max(~~(boW*0.55),~~(boW*(0.58+rng()*0.2))), po=~~(bR*0.5);
  const bCy = bRy2;
  rooms.push({id:'b',type:'boss',cx:bCx,cy:bCy,shape:rng()<0.72?'ellipse':'circle',rx:bR,ry:bRy2,
    pillars:[{dx:-po,dy:-~~(bRy2*0.5),w:3,h:3},{dx:po,dy:-~~(bRy2*0.5),w:3,h:3},
             {dx:-po,dy:~~(bRy2*0.5),w:3,h:3},{dx:po,dy:~~(bRy2*0.5),w:3,h:3}]});
  const bMY=~~((pY+bCy)/2);
  const bMX=Math.max(2,Math.min(mw-2,~~((pX+bCx)/2+(rng()-0.5)*mw*0.15)));
  corridors.push({from:pId,to:'b',width:bW+2+~~(rng()*2),style:_pickCorridorStyle(rng,floor,hell),waypoints:[{x:bMX,y:bMY}]});

  return{mw,mh,rooms,corridors,features,corridorSpawns};
}

// ── 내보내기 ──
function exportAsFixedMap(){
  let out=`// ══ EXODUSER FIXED_MAPS + GRID_MAPS 내보내기 ══\n\n`;
  // 격자맵의 스테이지 인덱스 매핑 (hell→stage index)
  const _gridStageIdx={};
  for(let i=0;i<STAGES.length;i++){if(STAGES[i].type==='grid')_gridStageIdx[STAGES[i].hell]=i;}
  if(mapMode==='grid'){
    out+='// ── 격자맵 FIXED_MAPS ──\n';
    for(let h=0;h<7;h++){
      if(!GRID_MAPS[h])continue;
      const si=_gridStageIdx[h];
      if(si!=null){
        const s=STAGES[si];
        out+=`// ${s.hell+1}장 ${s.floor}층 (격자)\nFIXED_MAPS[${si}]=${JSON.stringify(GRID_MAPS[h],null,2)};\n\n`;
      }
    }
  } else {
    out+='// ── 세로맵 FIXED_MAPS ──\n';
    for(let i=0;i<35;i++){if(!FIXED_MAPS[i])continue;const s=STAGES[i];out+=`// ${s.hell+1}장 ${s.floor}층\nFIXED_MAPS[${i}]=${JSON.stringify(FIXED_MAPS[i],null,2)};\n\n`;}
    // 격자맵도 FIXED_MAPS로 포함 (gridMapStore > GRID_MAPS > 자동생성 순)
    out+='\n// ── 격자맵 FIXED_MAPS ──\n';
    for(let h=0;h<7;h++){
      let _gm=gridMapStore[h]||null;
      let _gmData;
      if(_gm&&_gm.grid){
        // gridMapStore → FIXED_MAPS 형식 변환 (tileRLE 생성)
        const rle=[];const flat=[];
        for(let y=0;y<_gm.mh;y++)for(let x=0;x<_gm.mw;x++)flat.push(~~(_gm.grid[y]?.[x]||0));
        for(let i=0;i<flat.length;){const v=flat[i];let c=1;while(i+c<flat.length&&flat[i+c]===v&&c<65535)c++;rle.push(v,c);i+=c;}
        _gmData={mw:_gm.mw,mh:_gm.mh,rooms:_gm.rooms||[],corridors:[],features:[],corridorSpawns:[],
          spawnHoles:(_gm.objs||[]).filter(o=>o.id&&(o.id.startsWith('spawn')||o.id.startsWith('hole_'))).map(o=>({x:o.x,y:o.y,type:o.id==='hole_l'?'L':o.id==='hole_m'?'M':'S'})),
          tileRLE:rle};
      }else{
        if(!GRID_MAPS[h])GRID_MAPS[h]=generateGridMap(h);
        _gmData=GRID_MAPS[h];
      }
      const si=_gridStageIdx[h];
      if(si!=null){
        const s=STAGES[si];
        out+=`// ${s.hell+1}장 ${s.floor}층 (격자)\nFIXED_MAPS[${si}]=${JSON.stringify(_gmData,null,2)};\n\n`;
      }
    }
  }
  const blob=new Blob([out],{type:'text/plain'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download=`EXODUSER_${mapMode==='grid'?'격자':'일반'}맵.txt`;a.click();
  document.getElementById('stats').textContent='📤 내보내기 완료';
}

// ── 가로형 뱀 생성기 (좌→우, 9시→3시) ──
function genHoriz(si, forceSeed){
  const st=STAGES[si]; const mw=st.mw, mh=st.mh, hell=st.hell, floor=st.floor;
  if(forceSeed!==undefined) _sSeeds[si]=forceSeed;
  else if(_sSeeds[si]===undefined) _sSeeds[si]=si*7919+1;
  const rng=mkRng(_sSeeds[si]);

  const sc=1+si*0.014;
  const bW=Math.max(6,~~(6*sc));
  const arW=Math.max(8,~~(9*sc));
  const arH=Math.max(5,~~(6*sc));
  const boW=Math.max(11,~~(13*sc));
  const seg=Math.min(8,3+floor);

  // X 분할: 왼쪽(시작) → 오른쪽(보스)
  const lPad=bW+3, rPad=boW+2;
  const useW=mw-lPad-rPad;
  const sW=~~(useW/(seg+2));

  // Y 범위 — 맵 상하 끝 거의 다 씀
  const yMin=arH+2, yMax=mh-arH-2, yM=~~(mh/2);

  // 위아래 교차 Y 좌표 (세로 S자)
  const ys=[];
  let dir=rng()>0.5?1:-1;
  for(let i=0;i<seg;i++){
    const reach=0.70+rng()*0.25;
    const base=dir>0 ? ~~(yM+(yMax-yM)*reach) : ~~(yMin+(yM-yMin)*(1-reach));
    ys.push(Math.max(yMin,Math.min(yMax,base+~~((rng()-0.5)*mh*0.07))));
    dir*=-1;
  }

  const rooms=[], corridors=[], features=[], corridorSpawns=[];

  // 시작방 — 왼쪽 끝 (9시 방향)
  const sY=Math.max(yMin,Math.min(yMax,yM+~~((rng()-0.5)*mh*0.25)));
  const sX=lPad;
  rooms.push({id:'s',type:'start',cx:sX,cy:sY,shape:'ellipse',rx:~~(bW*0.7),ry:~~(bW*1.1)});
  let pId='s',pX=sX,pY=sY;

  const fAt=Math.max(1,~~(seg*0.38+rng()*seg*0.12));
  let ci=0;
  for(let i=0;i<seg;i++){
    const isF=(i===fAt);
    const id=isF?'f':'r'+(++ci);
    const rX=lPad+sW*(i+1);
    const rY=isF?yM:ys[i];
    const aW=isF?~~(arH*0.9):arW+~~(rng()*bW*0.5);
    const aH=isF?~~(arH*1.3):arH+~~(rng()*bW*0.4);
    const sh=isF?'rect':rng()<0.38?'circle':rng()<0.6?'ellipse':'cross';
    const gr=Math.min(3,~~(i/seg*3.5+hell*0.25));
    const sp=isF?undefined:[
      {dx:~~((rng()-0.5)*aW*0.7),dy:~~((rng()-0.5)*aH*0.9),grade:gr},
      {dx:~~((rng()-0.5)*aW*0.7),dy:~~((rng()-0.5)*aH*0.9),grade:gr},
      ...(gr>=2?[{dx:~~((rng()-0.5)*aW*0.6),dy:~~((rng()-0.5)*aH*0.7),grade:Math.min(3,gr+1)}]:[])
    ];
    const rd={id,type:isF?'forge':'combat',cx:rX,cy:rY,shape:sh,rx:aW,ry:aH};
    if(sp) rd.spawns=sp;
    if(sh==='cross'){rd.armW=~~(aW*0.5+rng()*aW*0.2);rd.armH=~~(aH*0.55+rng()*aH*0.2)}
    rooms.push(rd);

    // 복도 웨이포인트
    const wps=[];
    const wN=1+~~(rng()*2);
    for(let w=1;w<=wN;w++){
      const t=w/(wN+1);
      const wx=~~(pX+(rX-pX)*t);
      const wy=~~(pY+(rY-pY)*t+(rng()-0.5)*Math.abs(pX-rX)*0.25);
      wps.push({x:Math.max(2,Math.min(mw-2,wx)),y:Math.max(2,Math.min(mh-2,wy))});
    }
    const cStyle=_pickCorridorStyle(rng,floor,hell);
    corridors.push({from:pId,to:id,width:bW+~~(rng()*3),style:cStyle,waypoints:wps});

    if(rng()<0.45){
      const sp2=wps[~~(rng()*wps.length)];
      corridorSpawns.push({x:Math.max(2,Math.min(mw-2,sp2.x)),y:Math.max(2,Math.min(mh-2,sp2.y)),grade:Math.max(0,gr-1)});
    }
    if(rng()<0.35){
      const sd=rY<yM?-1:1;
      features.push({type:'alcove',x:Math.max(2,Math.min(mw-2,rX+~~((rng()-0.5)*aW*1.2))),y:Math.max(2,Math.min(mh-2,rY+sd*(aH+2+~~(rng()*4)))),r:3+~~(rng()*5+si*0.03)});
    }
    pId=id; pX=rX; pY=rY;
  }

  // 보스방 — 오른쪽 끝 (3시 방향), 동쪽 벽에 붙음
  const bCy=Math.max(boW+2,Math.min(mh-boW-2,yM+~~((rng()-0.5)*mh*0.2)));
  const bRx=~~(boW*0.65), bR=boW, po=~~(bR*0.5);
  const bCx=mw-bRx; // 오른쪽 끝에 붙음
  const po2=~~(bRx*0.5);
  rooms.push({id:'b',type:'boss',cx:bCx,cy:bCy,shape:rng()<0.68?'ellipse':'circle',rx:bRx,ry:bR,
    pillars:[{dx:-po2,dy:-~~(bR*0.5),w:3,h:3},{dx:po2,dy:-~~(bR*0.5),w:3,h:3},
             {dx:-po2,dy:~~(bR*0.5),w:3,h:3},{dx:po2,dy:~~(bR*0.5),w:3,h:3}]});
  const bMX=~~((pX+bCx)/2);
  const bMY=Math.max(2,Math.min(mh-2,~~((pY+bCy)/2+(rng()-0.5)*mh*0.12)));
  corridors.push({from:pId,to:'b',width:bW+2+~~(rng()*2),style:_pickCorridorStyle(rng,floor,hell),waypoints:[{x:bMX,y:bMY}]});

  if(rooms.length>=6&&rng()<0.5){
    const combat=rooms.filter(r=>r.type==='combat');
    if(combat.length>=3){
      const a=combat[~~(rng()*Math.max(1,combat.length-2))];
      const b=combat[Math.min(combat.length-1,Math.max(2,~~(rng()*combat.length)))];
      if(a&&b&&a.id!==b.id){
        const wx=~~((a.cx+b.cx)/2+(rng()-0.5)*Math.abs(a.cy-b.cy)*0.2);
        const wy=~~((a.cy+b.cy)/2+(rng()-0.5)*Math.abs(a.cx-b.cx)*0.15);
        corridors.push({from:a.id,to:b.id,width:Math.max(6,bW-1),style:_pickCorridorStyle(rng,floor,hell),waypoints:[{x:Math.max(2,Math.min(mw-2,wx)),y:Math.max(2,Math.min(mh-2,wy))}]});
      }
    }
  }

  return{mw,mh,rooms,corridors,features,corridorSpawns};
}


for(let i=0;i<70;i++){
  const s=STAGES[i];
  if(s.type==='grid'){
    // floor10: 격자맵 — GRID_MAPS[hell]로 처리 (getMap에서 분기)
    FIXED_MAPS[i]=null;
  } else if(s.type==='horiz'){
    FIXED_MAPS[i]=genHoriz(i);
  } else {
    FIXED_MAPS[i]=genSnake(i);
  }
}
for(let h=0;h<7;h++) GRID_MAPS[h]=generateGridMap(h);
try{
  const savedSlot=localStorage.getItem(EDITOR_SETTINGS_SLOT_KEY);
  _setSelectedSlot(savedSlot||1);
  const slotEl=_slotInput();
  if(slotEl){
    slotEl.addEventListener('change',()=>_setSelectedSlot(slotEl.value));
  }
}catch(e){}
window.addEventListener('beforeunload',()=>{ try{ _saveLiveMapState(); }catch(e){} });
window.addEventListener('pagehide',()=>{ try{ _saveLiveMapState(); }catch(e){} });
document.addEventListener('visibilitychange',()=>{ if(document.visibilityState==='hidden'){ try{ _saveLiveMapState(); }catch(e){} } });
setInterval(()=>{ try{ _saveLiveMapState(); }catch(e){} }, 5000);
(async()=>{
  try{ document.getElementById('stats').textContent=`에디터 빌드 ${BUILD_STAMP}`; }catch(e){}
  const ok = await loadEditorSettings(false);
  if(!ok){ buildChapterTabs(); buildStageListOrig(); loadStage(0); draw(); }
})();

</script>
</body></html>

